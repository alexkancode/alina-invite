---
// Pinterest-Style Photo Gallery Dashboard

// Simple authentication
const clientIP = Astro.clientAddress;
const allowedIPs = ['127.0.0.1', 'localhost'];
const adminPassword = 'admin123';
const providedPassword = Astro.url.searchParams.get('password');

const isAuthenticated = allowedIPs.includes(clientIP) || providedPassword === adminPassword;

if (!isAuthenticated) {
  return new Response('Unauthorized', { status: 401 });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>📸 Party Photo Gallery</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      color: #333;
    }

    .header {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      padding: 20px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 15px;
    }

    .title {
      font-size: 28px;
      font-weight: 700;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .stats {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    .stat-item {
      text-align: center;
      padding: 8px 16px;
      background: rgba(102, 126, 234, 0.1);
      border-radius: 12px;
    }

    .stat-number {
      font-size: 20px;
      font-weight: 700;
      color: #667eea;
    }

    .stat-label {
      font-size: 12px;
      color: #666;
      text-transform: uppercase;
    }

    .controls {
      display: flex;
      gap: 20px;
      align-items: center;
      flex-wrap: wrap;
    }

    .filter-group,
    .action-group {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .filter-label {
      font-size: 12px;
      font-weight: 600;
      color: #666;
      text-transform: uppercase;
      margin-right: 5px;
    }

    .search-box {
      padding: 10px 15px;
      border: 2px solid rgba(102, 126, 234, 0.2);
      border-radius: 25px;
      font-size: 14px;
      outline: none;
      background: rgba(255, 255, 255, 0.8);
    }

    .filter-btn {
      padding: 8px 16px;
      border: 2px solid rgba(102, 126, 234, 0.2);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.8);
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
    }

    .filter-btn.active {
      background: #667eea;
      color: white;
      border-color: #667eea;
    }

    .upload-btn {
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 25px;
      font-weight: 600;
      text-decoration: none;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 30px 20px;
    }

    .loading {
      text-align: center;
      padding: 60px 20px;
      color: white;
    }

    .loading-spinner {
      width: 50px;
      height: 50px;
      border: 4px solid rgba(255, 255, 255, 0.2);
      border-left: 4px solid white;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 20px;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    @keyframes slideOut {
      from {
        transform: translateX(0);
        opacity: 1;
      }
      to {
        transform: translateX(100%);
        opacity: 0;
      }
    }

  </style>

  <!-- Global styles for layout and dynamic content -->
  <style is:global>
    /* Pinterest-style masonry layout */
    .gallery {
      columns: 5;
      column-gap: 20px;
      margin-top: 20px;
    }

    @media (max-width: 1200px) { .gallery { columns: 4; } }
    @media (max-width: 900px) { .gallery { columns: 3; } }
    @media (max-width: 600px) { .gallery { columns: 2; column-gap: 15px; } }
    @media (max-width: 400px) { .gallery { columns: 1; } }

  </style>

  <!-- Global styles for dynamically generated content -->
  <style is:global>
    /* Beautiful Pinterest cards */
    .photo-card {
      break-inside: avoid;
      margin-bottom: 20px;
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
      cursor: pointer;
      position: relative;
    }

    .photo-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
    }

    .photo-card img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.3s ease;
      aspect-ratio: auto; /* Maintain aspect ratio */
      background: #f5f5f5; /* Placeholder while loading */
    }

    /* Virtual scrolling and lazy loading optimization */
    .photo-card.loading {
      background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
      min-height: 250px;
      position: relative;
    }

    .photo-card.loading::before {
      content: "📸";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 48px;
      opacity: 0.3;
      animation: pulse 2s infinite;
    }

    .photo-card.loading img {
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .photo-card.loaded img {
      opacity: 1;
    }

    .photo-card.loaded::before {
      display: none;
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 0.6; }
    }

    .photo-card:hover img {
      transform: scale(1.05);
    }

    .photo-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
      color: white;
      padding: 15px;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }

    .photo-card:hover .photo-overlay {
      transform: translateY(0);
    }

    .photo-info {
      font-size: 11px;
      opacity: 0.9;
    }

    .photo-type {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 12px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      margin-top: 8px;
    }

    .type-original {
      background: #4CAF50;
      color: white;
    }

    .type-user {
      background: #2196F3;
      color: white;
    }

    .type-admin {
      background: #FF9800;
      color: white;
    }

    .empty-state {
      text-align: center;
      padding: 80px 20px;
      color: white;
    }

    .fade-in {
      animation: fadeInUp 0.6s ease-out;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Modal */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.9);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .modal.show {
      display: flex;
    }

    .modal-content {
      max-width: 90vw;
      max-height: 90vh;
      position: relative;
    }

    .modal img {
      max-width: 100%;
      max-height: 100%;
      border-radius: 12px;
    }

    .modal-close {
      position: absolute;
      top: -10px;
      right: -10px;
      background: white;
      border: none;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 18px;
    }

    /* Selection Mode Styles */
    .photo-card.selectable {
      cursor: pointer;
    }

    .photo-card.selectable:hover .photo-checkbox {
      opacity: 1;
    }

    .photo-card.selected {
      ring: 4px solid #667eea;
      box-shadow: 0 0 0 4px #667eea;
    }

    .photo-checkbox {
      position: absolute;
      top: 35px;
      right: 8px;
      width: 24px;
      height: 24px;
      background: rgba(255, 255, 255, 0.9);
      border: 2px solid #ddd;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
      z-index: 10;
    }

    .photo-checkbox.checked {
      background: #667eea;
      border-color: #667eea;
      opacity: 1;
    }

    .photo-checkbox.checked::after {
      content: "✓";
      color: white;
      font-weight: bold;
      font-size: 14px;
    }

    .selection-mode .photo-checkbox {
      opacity: 1;
    }

    .selection-mode .photo-card {
      cursor: pointer;
    }

    .selection-mode .photo-card:hover {
      transform: translateY(-2px);
    }

    /* Photo Info Overlays */
    .photo-resolution {
      position: absolute;
      top: 8px;
      right: 8px;
      background: rgba(0, 0, 0, 0.7);
      color: white;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      z-index: 5;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .photo-folder {
      position: absolute;
      top: 8px;
      left: 8px;
      background: rgba(102, 126, 234, 0.9);
      color: white;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      z-index: 5;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .photo-card:hover .photo-resolution,
    .photo-card:hover .photo-folder {
      opacity: 1;
    }

    /* Different folder colors */
    .folder-thumbs {
      background: rgba(102, 126, 234, 0.9);
    }

    .folder-minigame {
      background: rgba(156, 39, 176, 0.9);
    }

    .folder-original {
      background: rgba(76, 175, 80, 0.9);
    }


    .folder-adminuploads {
      background: rgba(255, 87, 34, 0.9);
    }

    .folder-useruploads {
      background: rgba(33, 150, 243, 0.9);
    }
  </style>
</head>
<body>
  <!-- Header -->
  <div class="header">
    <div class="header-content">
      <h1 class="title">📸 Party Photo Gallery</h1>

      <div class="stats">
        <div class="stat-item">
          <div class="stat-number" id="totalCount">0</div>
          <div class="stat-label">Total</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="originalCount">0</div>
          <div class="stat-label">Original</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="userCount">0</div>
          <div class="stat-label">User</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="adminCount">0</div>
          <div class="stat-label">Admin</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="thumbsCount">0</div>
          <div class="stat-label">📁 Thumbs</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="minigameCount">0</div>
          <div class="stat-label">🎮 Minigame</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="originalFolderCount">0</div>
          <div class="stat-label">🌟 Original</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="userUploadsCount">0</div>
          <div class="stat-label">👤 User Uploads</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="adminUploadsCount">0</div>
          <div class="stat-label">👨‍💼 Admin Uploads</div>
        </div>
      </div>

      <div class="controls">
        <input type="text" class="search-box" placeholder="Search photos..." id="searchInput">

        <div class="filter-group">
          <span class="filter-label">Type:</span>
          <button class="filter-btn active" data-filter="all" data-filter-type="type">All</button>
          <button class="filter-btn" data-filter="original" data-filter-type="type">Original</button>
          <button class="filter-btn" data-filter="user" data-filter-type="type">User</button>
          <button class="filter-btn" data-filter="admin" data-filter-type="type">Admin</button>
        </div>

        <div class="filter-group">
          <span class="filter-label">Folder:</span>
          <button class="filter-btn active" data-filter="all-folders" data-filter-type="folder">All</button>
          <button class="filter-btn" data-filter="thumbs" data-filter-type="folder">📁 Thumbs</button>
          <button class="filter-btn" data-filter="minigame" data-filter-type="folder">🎮 Minigame</button>
          <button class="filter-btn" data-filter="original" data-filter-type="folder">🌟 Original</button>
          <button class="filter-btn" data-filter="user-uploads" data-filter-type="folder">👤 User Uploads</button>
          <button class="filter-btn" data-filter="admin-uploads" data-filter-type="folder">👨‍💼 Admin Uploads</button>
        </div>

        <div class="action-group">
          <button id="selectModeBtn" class="filter-btn">📋 Select</button>
          <button id="selectAllBtn" class="filter-btn" style="display: none;">☑️ Select All</button>
          <button id="deleteSelectedBtn" class="upload-btn" style="display: none; background: #e74c3c;">🗑️ Delete Selected</button>
          <a href="/admin/upload" class="upload-btn">➕ Upload Photos</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container">
    <div id="loading" class="loading">
      <div class="loading-spinner"></div>
      <p>Loading your beautiful photos...</p>
    </div>

    <div id="gallery" class="gallery" style="display: none;"></div>

    <div id="emptyState" class="empty-state" style="display: none;">
      <h2>No photos yet!</h2>
      <p>Upload some photos to get started</p>
      <br>
      <a href="/admin/upload" class="upload-btn">Upload Your First Photo</a>
    </div>
  </div>

  <!-- Photo Modal -->
  <div id="photoModal" class="modal">
    <div class="modal-content">
      <button class="modal-close" onclick="closeModal()">&times;</button>
      <img id="modalImage" src="" alt="">
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteModal" class="modal">
    <div class="modal-content" style="background: white; padding: 30px; border-radius: 16px; text-align: center; max-width: 400px;">
      <h2 style="color: #e74c3c; margin-bottom: 15px;">🗑️ Confirm Deletion</h2>
      <p style="margin-bottom: 20px; color: #666;">
        Are you sure you want to delete <strong id="deleteCount">0</strong> selected photo(s)?
      </p>
      <p style="margin-bottom: 25px; font-size: 14px; color: #999;">
        This action cannot be undone.
      </p>
      <div style="display: flex; gap: 15px; justify-content: center;">
        <button onclick="closeDeleteModal()" style="padding: 12px 20px; border: 2px solid #ddd; background: white; border-radius: 8px; cursor: pointer;">Cancel</button>
        <button onclick="confirmDelete()" style="padding: 12px 20px; border: none; background: #e74c3c; color: white; border-radius: 8px; cursor: pointer; font-weight: 600;">Delete</button>
      </div>
    </div>
  </div>

  <script>
    let allPhotos = [];
    let currentTypeFilter = 'all';
    let currentFolderFilter = 'all-folders';
    let isSelectionMode = false;
    let selectedPhotos = new Set();

    // Virtual scrolling state
    let virtualState = {
      containerHeight: 0,
      scrollTop: 0,
      itemHeight: 300, // Estimated average card height
      bufferSize: 5, // Extra items to render above/below viewport
      visibleStart: 0,
      visibleEnd: 0,
      totalItems: 0
    };

    // Debouncing
    let searchTimeout;
    let filterTimeout;

    // Intersection Observer for lazy loading
    let imageObserver;

    function initIntersectionObserver() {
      if (imageObserver) {
        imageObserver.disconnect();
      }

      imageObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            const dataSrc = img.dataset.src;

            if (dataSrc) {
              img.src = dataSrc;
              img.removeAttribute('data-src');
              imageObserver.unobserve(img);

              img.onload = () => {
                img.parentElement.classList.add('loaded');
              };
            }
          }
        });
      }, {
        rootMargin: '50px' // Start loading 50px before entering viewport
      });
    }

    async function loadPhotos() {
      try {
        console.log('Loading photos...');
        const response = await fetch('/api/admin/all-photos');

        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        console.log('Photos loaded:', data);
        console.log('Total photos count:', data.totalPhotos);

        if (data.success && data.photos && data.photos.length > 0) {
          allPhotos = data.photos;
          console.log('Setting allPhotos array length:', allPhotos.length);
          updateStats(data.counts, data.totalPhotos);
          renderPhotos();
        } else {
          console.error('No photos returned or empty array');
          showEmptyState();
        }
      } catch (error) {
        console.error('Error loading photos:', error);
        showEmptyState();
      }

      document.getElementById('loading').style.display = 'none';
    }

    function updateStats(counts, total) {
      document.getElementById('totalCount').textContent = total;
      document.getElementById('originalCount').textContent = counts.original;
      document.getElementById('userCount').textContent = counts.user;
      document.getElementById('adminCount').textContent = counts.admin;

      // Calculate folder counts
      const folderCounts = {};
      allPhotos.forEach(photo => {
        const folder = photo.folder || 'unknown';
        folderCounts[folder] = (folderCounts[folder] || 0) + 1;
      });

      // Debug: Log folder distribution
      console.log('Folder distribution:', folderCounts);
      console.log('Total photos by folder:', Object.keys(folderCounts).map(f => `${f}: ${folderCounts[f]}`).join(', '));

      document.getElementById('thumbsCount').textContent = folderCounts.thumbs || 0;
      document.getElementById('minigameCount').textContent = folderCounts.minigame || 0;
      document.getElementById('originalFolderCount').textContent = folderCounts.original || 0;
      document.getElementById('userUploadsCount').textContent = folderCounts['user-uploads'] || 0;
      document.getElementById('adminUploadsCount').textContent = folderCounts['admin-uploads'] || 0;
    }

    function calculateVirtualWindow() {
      const container = document.querySelector('.container');
      if (!container) return;

      const containerRect = container.getBoundingClientRect();
      const scrollTop = container.scrollTop || window.pageYOffset;

      virtualState.containerHeight = containerRect.height;
      virtualState.scrollTop = scrollTop;

      // Calculate visible range with buffer
      const startIndex = Math.max(0, Math.floor(scrollTop / virtualState.itemHeight) - virtualState.bufferSize);
      const endIndex = Math.min(
        virtualState.totalItems,
        Math.ceil((scrollTop + virtualState.containerHeight) / virtualState.itemHeight) + virtualState.bufferSize
      );

      virtualState.visibleStart = startIndex;
      virtualState.visibleEnd = endIndex;
    }

    function renderVirtualPhotos() {
      console.log('Rendering virtual photos...');
      const gallery = document.getElementById('gallery');

      if (!gallery) {
        console.error('Gallery element not found!');
        return;
      }

      const filteredPhotos = filterPhotos();
      console.log('Filtered photos count:', filteredPhotos.length);

      if (filteredPhotos.length === 0) {
        console.log('No filtered photos, showing empty state');
        showEmptyState();
        return;
      }

      console.log('Setting gallery display to block and hiding empty state');
      gallery.style.display = 'block';
      document.getElementById('emptyState').style.display = 'none';

      // Update virtual state
      virtualState.totalItems = filteredPhotos.length;
      calculateVirtualWindow();

      // Only render visible items
      const visiblePhotos = filteredPhotos.slice(virtualState.visibleStart, virtualState.visibleEnd);
      console.log(`Rendering ${visiblePhotos.length} of ${filteredPhotos.length} photos (${virtualState.visibleStart}-${virtualState.visibleEnd})`);

      const galleryHTML = visiblePhotos.map(photo => {
        const canDelete = photo.type === 'user' || photo.type === 'admin';
        const isSelected = selectedPhotos.has(photo.path);
        const resolution = photo.width && photo.height ? `${photo.width}×${photo.height}` : 'Unknown';
        const folder = photo.folder || 'unknown';

        return `
          <div class="photo-card loading ${isSelectionMode && canDelete ? 'selectable' : ''} ${isSelected ? 'selected' : ''}"
               data-photo-path="${photo.path}"
               data-can-delete="${canDelete}"
               onclick="handlePhotoClick('${photo.path}', ${canDelete})">
            <img data-src="${photo.path}?v=${Date.now()}" alt="${photo.filename}" loading="lazy">

            <!-- Top overlays -->
            <div class="photo-folder folder-${folder.replace('-', '')}">${folder}</div>
            <div class="photo-resolution">${resolution}</div>

            ${isSelectionMode && canDelete ? `<div class="photo-checkbox ${isSelected ? 'checked' : ''}"></div>` : ''}
            <div class="photo-overlay">
              <div class="photo-info">
                <strong>${photo.filename}</strong><br>
                ${formatFileSize(photo.size)}<br>
                ${formatDate(photo.modified)}
                ${!canDelete ? '<br><em style="color: #ffd700;">Protected</em>' : ''}
              </div>
              <span class="photo-type type-${photo.type}">${photo.type}</span>
            </div>
          </div>
        `;
      }).join('');

      console.log('Generated virtual HTML length:', galleryHTML.length);
      gallery.innerHTML = galleryHTML;
      console.log('Virtual gallery set, rendered children count:', gallery.children.length);

      // Observe images for lazy loading
      const images = gallery.querySelectorAll('img[data-src]');
      images.forEach(img => imageObserver.observe(img));
    }

    // Fallback to regular rendering for smaller galleries
    function renderPhotos() {
      console.log('🔄 renderPhotos() called, stack trace:', new Error().stack);
      const filteredPhotos = filterPhotos();
      console.log('📊 Filtered photos count:', filteredPhotos.length);

      // Temporarily disable virtual scrolling for debugging
      // Use virtual scrolling for galleries with 50+ items
      // if (filteredPhotos.length >= 50) {
      //   renderVirtualPhotos();
      // } else {
        renderRegularPhotos();
      // }
    }

    function renderRegularPhotos() {
      console.log('🎨 renderRegularPhotos() starting...');
      const gallery = document.getElementById('gallery');

      if (!gallery) {
        console.error('❌ Gallery element not found!');
        return;
      }

      const filteredPhotos = filterPhotos();
      console.log('📸 Filtered photos count for render:', filteredPhotos.length);

      if (filteredPhotos.length === 0) {
        console.log('⚠️ No filtered photos, showing empty state');
        showEmptyState();
        return;
      }

      console.log('✅ Setting gallery display to block and hiding empty state');
      gallery.style.display = 'block';
      document.getElementById('emptyState').style.display = 'none';

      const galleryHTML = filteredPhotos.map(photo => {
        const canDelete = photo.type === 'user' || photo.type === 'admin';
        const isSelected = selectedPhotos.has(photo.path);
        const resolution = photo.width && photo.height ? `${photo.width}×${photo.height}` : 'Unknown';
        const folder = photo.folder || 'unknown';

        return `
          <div class="photo-card loading ${isSelectionMode && canDelete ? 'selectable' : ''} ${isSelected ? 'selected' : ''}"
               data-photo-path="${photo.path}"
               data-can-delete="${canDelete}"
               onclick="handlePhotoClick('${photo.path}', ${canDelete})">
            <img data-src="${photo.path}?v=${Date.now()}" alt="${photo.filename}" loading="lazy">

            <!-- Top overlays -->
            <div class="photo-folder folder-${folder.replace('-', '')}">${folder}</div>
            <div class="photo-resolution">${resolution}</div>

            ${isSelectionMode && canDelete ? `<div class="photo-checkbox ${isSelected ? 'checked' : ''}"></div>` : ''}
            <div class="photo-overlay">
              <div class="photo-info">
                <strong>${photo.filename}</strong><br>
                ${formatFileSize(photo.size)}<br>
                ${formatDate(photo.modified)}
                ${!canDelete ? '<br><em style="color: #ffd700;">Protected</em>' : ''}
              </div>
              <span class="photo-type type-${photo.type}">${photo.type}</span>
            </div>
          </div>
        `;
      }).join('');

      console.log('📝 Generated HTML length:', galleryHTML.length);
      gallery.innerHTML = galleryHTML;
      console.log('🏁 Gallery innerHTML set, current children count:', gallery.children.length);

      // Observe images for lazy loading
      const images = gallery.querySelectorAll('img[data-src]');
      images.forEach(img => imageObserver.observe(img));
      console.log('👁️ Set up lazy loading for', images.length, 'images');
      console.log('✨ renderRegularPhotos() COMPLETED successfully!');
    }

    function filterPhotos() {
      const searchTerm = document.getElementById('searchInput').value.toLowerCase();

      return allPhotos.filter(photo => {
        // Type filter
        const matchesTypeFilter = currentTypeFilter === 'all' || photo.type === currentTypeFilter;

        // Folder filter
        const matchesFolderFilter = currentFolderFilter === 'all-folders' || photo.folder === currentFolderFilter;

        // Search filter
        const matchesSearch = photo.filename.toLowerCase().includes(searchTerm);

        return matchesTypeFilter && matchesFolderFilter && matchesSearch;
      });
    }

    function showEmptyState() {
      document.getElementById('gallery').style.display = 'none';
      document.getElementById('emptyState').style.display = 'block';
    }

    function formatFileSize(bytes) {
      if (!bytes) return 'Unknown size';
      const kb = bytes / 1024;
      return kb < 1024 ? `${Math.round(kb)}KB` : `${Math.round(kb / 1024 * 10) / 10}MB`;
    }

    function formatDate(dateString) {
      if (!dateString) return 'Unknown date';
      return new Date(dateString).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    window.handlePhotoClick = function(photoPath, canDelete) {
      if (isSelectionMode && canDelete) {
        togglePhotoSelection(photoPath);
      } else if (!isSelectionMode) {
        openModal(photoPath);
      }
    }

    function togglePhotoSelection(photoPath) {
      if (selectedPhotos.has(photoPath)) {
        selectedPhotos.delete(photoPath);
      } else {
        selectedPhotos.add(photoPath);
      }

      // Update only the specific photo card instead of full re-render
      updatePhotoSelectionUI(photoPath);
      updateSelectionUI();
    }

    function updatePhotoSelectionUI(photoPath) {
      const photoCard = document.querySelector(`[data-photo-path="${photoPath}"]`);
      if (!photoCard) return;

      const isSelected = selectedPhotos.has(photoPath);
      const checkbox = photoCard.querySelector('.photo-checkbox');

      // Update card selection state
      if (isSelected) {
        photoCard.classList.add('selected');
        if (checkbox) checkbox.classList.add('checked');
      } else {
        photoCard.classList.remove('selected');
        if (checkbox) checkbox.classList.remove('checked');
      }
    }

    function toggleSelectionMode() {
      isSelectionMode = !isSelectionMode;
      selectedPhotos.clear();

      const gallery = document.getElementById('gallery');
      const selectBtn = document.getElementById('selectModeBtn');
      const selectAllBtn = document.getElementById('selectAllBtn');
      const deleteBtn = document.getElementById('deleteSelectedBtn');

      if (isSelectionMode) {
        gallery.classList.add('selection-mode');
        selectBtn.textContent = '❌ Cancel';
        selectBtn.classList.add('active');
        selectAllBtn.style.display = 'inline-block';
        deleteBtn.style.display = 'inline-block';
      } else {
        gallery.classList.remove('selection-mode');
        selectBtn.textContent = '📋 Select';
        selectBtn.classList.remove('active');
        selectAllBtn.style.display = 'none';
        deleteBtn.style.display = 'none';
      }

      updateSelectionUI();
      renderPhotos();
    }

    function selectAllVisible() {
      const filteredPhotos = filterPhotos();
      const deletablePhotos = filteredPhotos.filter(photo =>
        photo.type === 'user' || photo.type === 'admin'
      );

      // Check if all deletable photos are already selected
      const allSelected = deletablePhotos.length > 0 &&
        deletablePhotos.every(photo => selectedPhotos.has(photo.path));

      if (allSelected) {
        // Deselect all visible deletable photos
        deletablePhotos.forEach(photo => {
          selectedPhotos.delete(photo.path);
          updatePhotoSelectionUI(photo.path);
        });
      } else {
        // Select all visible deletable photos
        deletablePhotos.forEach(photo => {
          selectedPhotos.add(photo.path);
          updatePhotoSelectionUI(photo.path);
        });
      }

      updateSelectionUI();
      // No need to re-render since we updated individual cards
    }

    function updateSelectionUI() {
      const deleteBtn = document.getElementById('deleteSelectedBtn');
      const selectAllBtn = document.getElementById('selectAllBtn');
      const count = selectedPhotos.size;

      if (count > 0) {
        deleteBtn.textContent = `🗑️ Delete (${count})`;
        deleteBtn.disabled = false;
      } else {
        deleteBtn.textContent = '🗑️ Delete Selected';
        deleteBtn.disabled = true;
      }

      // Update Select All button text
      if (isSelectionMode) {
        const filteredPhotos = filterPhotos();
        const deletablePhotos = filteredPhotos.filter(photo =>
          photo.type === 'user' || photo.type === 'admin'
        );
        const allSelected = deletablePhotos.length > 0 &&
          deletablePhotos.every(photo => selectedPhotos.has(photo.path));

        selectAllBtn.textContent = allSelected ? '☑️ Deselect All' : '☑️ Select All';
      }
    }

    function openDeleteModal() {
      const count = selectedPhotos.size;
      if (count === 0) return;

      document.getElementById('deleteCount').textContent = count;
      document.getElementById('deleteModal').classList.add('show');
    }

    window.closeDeleteModal = function() {
      document.getElementById('deleteModal').classList.remove('show');
    }

    window.confirmDelete = async function() {
      const photosToDelete = Array.from(selectedPhotos);

      try {
        const response = await fetch('/api/admin/delete-photos', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            photos: photosToDelete
          })
        });

        const result = await response.json();

        if (result.success) {
          // Clear selections and exit selection mode
          selectedPhotos.clear();
          toggleSelectionMode();

          // Reload photos
          await loadPhotos();

          closeDeleteModal();

          // Show success message briefly
          showNotification(`Successfully deleted ${result.deletedCount} photo(s)`, 'success');
        } else {
          showNotification(`Error: ${result.error}`, 'error');
        }
      } catch (error) {
        console.error('Delete error:', error);
        showNotification('Failed to delete photos', 'error');
      }
    }

    function showNotification(message, type) {
      // Create a simple notification
      const notification = document.createElement('div');
      notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 15px 20px;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        z-index: 10000;
        animation: slideIn 0.3s ease-out;
        background: ${type === 'success' ? '#4CAF50' : '#e74c3c'};
      `;
      notification.textContent = message;

      document.body.appendChild(notification);

      setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease-in';
        setTimeout(() => document.body.removeChild(notification), 300);
      }, 3000);
    }

    function openModal(imageSrc) {
      const modal = document.getElementById('photoModal');
      const modalImage = document.getElementById('modalImage');

      modalImage.src = imageSrc;
      modal.classList.add('show');
    }

    window.closeModal = function() {
      document.getElementById('photoModal').classList.remove('show');
    }

    // Debounced search function
    function debouncedSearch() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        renderPhotos();
      }, 300); // Wait 300ms after user stops typing
    }

    // Event listeners
    document.getElementById('searchInput').addEventListener('input', debouncedSearch);

    document.querySelectorAll('.filter-btn[data-filter-type]').forEach(btn => {
      btn.addEventListener('click', () => {
        const filterType = btn.dataset.filterType;
        const filterValue = btn.dataset.filter;

        if (filterType === 'type') {
          // Remove active from all type filter buttons
          document.querySelectorAll('.filter-btn[data-filter-type="type"]').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentTypeFilter = filterValue;
        } else if (filterType === 'folder') {
          // Remove active from all folder filter buttons
          document.querySelectorAll('.filter-btn[data-filter-type="folder"]').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentFolderFilter = filterValue;
        }

        renderPhotos();
      });
    });

    document.getElementById('photoModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeModal();
    });

    document.getElementById('deleteModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeDeleteModal();
    });

    document.getElementById('selectModeBtn').addEventListener('click', toggleSelectionMode);

    document.getElementById('selectAllBtn').addEventListener('click', selectAllVisible);

    document.getElementById('deleteSelectedBtn').addEventListener('click', openDeleteModal);


    // Initialize intersection observer
    initIntersectionObserver();

    // Load photos on page load
    loadPhotos();

    // Throttled scroll handler for virtual scrolling
    let scrollTimeout;
    function throttledScroll() {
      if (scrollTimeout) return;

      scrollTimeout = setTimeout(() => {
        const filteredPhotos = filterPhotos();
        if (filteredPhotos.length >= 50) {
          renderVirtualPhotos();
        }
        scrollTimeout = null;
      }, 16); // ~60fps
    }

    // Temporarily disable scroll listeners and auto-refresh for debugging
    // window.addEventListener('scroll', throttledScroll);
    // document.querySelector('.container')?.addEventListener('scroll', throttledScroll);

    // Auto-refresh every 30 seconds - DISABLED FOR DEBUGGING
    // setInterval(loadPhotos, 30000);
  </script>
</body>
</html>