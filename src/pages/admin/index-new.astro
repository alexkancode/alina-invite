---
// Enhanced Admin Portal with Tab Interface
import AdminTabs from '../../components/admin/AdminTabs.astro';
import PhotoManager from '../../components/admin/PhotoManager.astro';
import OverlayManager from '../../components/admin/OverlayManager.astro';
import CombinedPreview from '../../components/admin/CombinedPreview.astro';

// Simple authentication
const clientIP = Astro.clientAddress;
const allowedIPs = ['127.0.0.1', 'localhost'];
const adminPassword = 'admin123';
const providedPassword = Astro.url.searchParams.get('password');

const isAuthenticated = allowedIPs.includes(clientIP) || providedPassword === adminPassword;

if (!isAuthenticated) {
  return new Response('Unauthorized', { status: 401 });
}

const tabs = [
  { id: 'photos', label: 'Photo Gallery', icon: '📷' },
  { id: 'overlays', label: 'Overlay Effects', icon: '✨' }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>📸 Party Photo Gallery Admin</title>
  <link href="/src/styles/global.css" rel="stylesheet" />
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      margin: 0;
      padding: 0;
    }

    .admin-header {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      padding: var(--spacing-phi-lg);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--spacing-phi-md);
    }

    .admin-title {
      font-size: var(--font-size-phi-lg);
      font-weight: 700;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .header-stats {
      display: flex;
      gap: var(--spacing-phi-lg);
      flex-wrap: wrap;
    }

    .stat-item {
      text-align: center;
      padding: var(--spacing-phi-sm) var(--spacing-phi-md);
      background: rgba(102, 126, 234, 0.1);
      border-radius: var(--radius-lg);
    }

    .stat-number {
      font-size: var(--font-size-phi-md);
      font-weight: 700;
      color: #667eea;
    }

    .stat-label {
      font-size: 0.75rem;
      color: #666;
      text-transform: uppercase;
    }

    .main-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: var(--spacing-phi-xl);
    }

    .admin-layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--spacing-phi-xl);
    }

    @media (min-width: 1200px) {
      .admin-layout {
        grid-template-columns: 2fr 1fr;
      }
    }

    .main-content {
      background: var(--color-paper);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-elevation-medium);
      overflow: hidden;
    }

    .sidebar-content {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-phi-lg);
    }
  </style>
</head>
<body>
  <header class="admin-header">
    <div class="header-content">
      <h1 class="admin-title">📸 Party Photo Gallery Admin</h1>

      <div class="header-stats" id="header-stats">
        <div class="stat-item">
          <div class="stat-number" id="total-photos">0</div>
          <div class="stat-label">Photos</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="total-overlays">0</div>
          <div class="stat-label">Overlays</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" id="active-effects">0</div>
          <div class="stat-label">Active Effects</div>
        </div>
      </div>
    </div>
  </header>

  <main class="main-container">
    <div class="admin-layout">
      <div class="main-content">
        <AdminTabs tabs={tabs} defaultTab="photos">
          <div slot="photos">
            <PhotoManager />
          </div>
          <div slot="overlays">
            <OverlayManager />
          </div>
        </AdminTabs>
      </div>

      <div class="sidebar-content">
        <CombinedPreview />
      </div>
    </div>
  </main>

  <script>
    class AdminDashboard {
      private photoCount: HTMLElement;
      private overlayCount: HTMLElement;
      private activeEffects: HTMLElement;

      constructor() {
        this.initializeElements();
        this.setupEventListeners();
        this.updateStats();
      }

      private initializeElements(): void {
        this.photoCount = document.getElementById('total-photos')!;
        this.overlayCount = document.getElementById('total-overlays')!;
        this.activeEffects = document.getElementById('active-effects')!;
      }

      private setupEventListeners(): void {
        document.addEventListener('photosUpdated', this.handlePhotosUpdated.bind(this));
        document.addEventListener('overlaysUpdated', this.handleOverlaysUpdated.bind(this));
        document.addEventListener('tabChanged', this.handleTabChanged.bind(this));
      }

      private handlePhotosUpdated(event: CustomEvent): void {
        const photos = event.detail.photos || [];
        this.photoCount.textContent = photos.length.toString();
        this.updateActiveEffects();
      }

      private handleOverlaysUpdated(event: CustomEvent): void {
        const overlays = event.detail.overlays || [];
        const activeOverlays = overlays.filter((overlay: any) => overlay.active);
        this.overlayCount.textContent = overlays.length.toString();
        this.activeEffects.textContent = activeOverlays.length.toString();
      }

      private handleTabChanged(event: CustomEvent): void {
        const { activeTab } = event.detail;
        document.title = `📸 Party Photo Gallery Admin - ${this.getTabDisplayName(activeTab)}`;
      }

      private getTabDisplayName(tabId: string): string {
        const tabNames = {
          photos: 'Photo Gallery',
          overlays: 'Overlay Effects'
        };
        return tabNames[tabId as keyof typeof tabNames] || 'Admin';
      }

      private updateActiveEffects(): void {
        const currentOverlays = parseInt(this.overlayCount.textContent || '0');
        const currentPhotos = parseInt(this.photoCount.textContent || '0');
        const effectiveCount = Math.min(currentOverlays, currentPhotos);

        if (this.activeEffects.textContent !== effectiveCount.toString()) {
          this.activeEffects.textContent = effectiveCount.toString();
        }
      }

      private async updateStats(): Promise<void> {
        try {
          const [photosResponse, overlaysResponse] = await Promise.all([
            fetch('/api/admin/photos'),
            fetch('/api/admin/overlays')
          ]);

          if (photosResponse.ok) {
            const photos = await photosResponse.json();
            this.photoCount.textContent = photos.length.toString();
          }

          if (overlaysResponse.ok) {
            const overlays = await overlaysResponse.json();
            const activeOverlays = overlays.filter((overlay: any) => overlay.active);
            this.overlayCount.textContent = overlays.length.toString();
            this.activeEffects.textContent = activeOverlays.length.toString();
          }
        } catch (error) {
          console.error('Failed to load initial stats:', error);
        }
      }
    }

    new AdminDashboard();
  </script>
</body>
</html>