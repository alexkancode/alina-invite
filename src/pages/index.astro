    <main class="relative z-10 max-w-[791px] mx-auto px-phi-lg py-phi-3xl">

      <!-- ═══ Disco Ball Hero ═══ -->
      <header class="text-center space-y-phi-lg flex flex-col justify-end relative" style="min-height: 0;">
        <!-- Mini disco ball motif (hidden for now)
        <div class="mx-auto w-[89px] h-[89px] rounded-full relative"
             style="background: conic-gradient(from 0deg, #BCC6CC, #FFD700, #BCC6CC, #5D3FD3, #BCC6CC, #FF007F, #BCC6CC, #FFD700);
                    animation: disco-rotate 8s linear infinite;
                    box-shadow: 0 0 34px hsl(45, 100%, 50% / 0.4), 0 0 55px hsl(280, 60%, 50% / 0.2);">
          <div class="absolute inset-0 rounded-full opacity-40"
               style="background:
                 repeating-linear-gradient(0deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px),
                 repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px);">
          </div>
        </div>
        -->

        <!-- Purpose statement (absolute, doesn't affect flow) -->
        <svg viewBox="0 0 2750 1375" class="arc-text-svg w-full max-w-[600px] overflow-visible" style="position: absolute; top: 50px; left: 50%; transform: translateX(-50%);" >
          <defs>
            <path id="text-arc" d="M 650,1350 A 650,650 0 0,1 2100,1350" fill="none" />
          </defs>
          <!-- Sun circle (behind disco ball) -->
          <defs>
            <linearGradient id="iri-bg" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="hsl(280, 40%, 25%)" />
              <stop offset="20%" stop-color="hsl(200, 50%, 20%)" />
              <stop offset="40%" stop-color="hsl(160, 45%, 22%)" />
              <stop offset="60%" stop-color="hsl(300, 35%, 28%)" />
              <stop offset="80%" stop-color="hsl(220, 50%, 18%)" />
              <stop offset="100%" stop-color="hsl(280, 40%, 25%)" />
            </linearGradient>
          </defs>
          <circle cx="1375" cy="1300" r="600" fill="url(#iri-bg)" />
          <text style="font-family: 'Chicle', sans-serif; font-size: 132px; font-weight: 500;
                       letter-spacing: 0.05em;"
                fill="#483D8B">
            <textPath href="#text-arc" startOffset="50%" text-anchor="middle">
              Let's celebrate Alina's first year of life!
            </textPath>
          </text>
        </svg>

