---
import '../styles/global.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>You're Invited</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Righteous&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen overflow-x-hidden relative"
        style="font-family: 'Poppins', sans-serif;
               background:
                 radial-gradient(ellipse at 30% 20%, hsl(280, 60%, 25% / 0.6), transparent 50%),
                 radial-gradient(ellipse at 70% 80%, hsl(35, 100%, 40% / 0.3), transparent 50%),
                 linear-gradient(180deg, #1a0a2e 0%, #2d1254 40%, #1a0a2e 100%);">

    <!-- ═══ Sliding bar animation ═══ -->
    <div id="sliding-bar" class="fixed top-0 left-0 w-[50vw] pointer-events-none"
         style="height: 25px;
                z-index: 100;
                background: hsl(220, 35%, 30%);
                clip-path: inset(0 100% 0 0);
                animation: sliding-bar 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed left-0 w-[50vw] pointer-events-none"
         style="top: 25px;
                height: 25px;
                z-index: 100;
                background: #FFD700;
                clip-path: inset(0 100% 0 0);
                animation: sliding-bar 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed left-0 w-[50vw] pointer-events-none"
         style="top: 50px;
                height: 25px;
                z-index: 100;
                background: #FF007F;
                clip-path: inset(0 100% 0 0);
                animation: sliding-bar 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed left-0 w-[50vw] pointer-events-none"
         style="top: 75px;
                height: 25px;
                z-index: 100;
                background: #5cc8e6;
                clip-path: inset(0 100% 0 0);
                animation: sliding-bar 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed left-0 w-[50vw] pointer-events-none"
         style="top: 100px;
                height: 25px;
                z-index: 100;
                background: #E2725B;
                clip-path: inset(0 100% 0 0);
                animation: sliding-bar 2s linear infinite;
                animation-delay: 1s;">
    </div>

    <!-- ═══ Sliding bars from right ═══ -->
    <div class="fixed right-0 w-[50vw] pointer-events-none"
         style="top: 0; height: 25px; z-index: 100;
                background: hsl(220, 35%, 30%);
                clip-path: inset(0 0 0 100%);
                animation: sliding-bar-rtl 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed right-0 w-[50vw] pointer-events-none"
         style="top: 25px; height: 25px; z-index: 100;
                background: #FFD700;
                clip-path: inset(0 0 0 100%);
                animation: sliding-bar-rtl 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed right-0 w-[50vw] pointer-events-none"
         style="top: 50px; height: 25px; z-index: 100;
                background: #FF007F;
                clip-path: inset(0 0 0 100%);
                animation: sliding-bar-rtl 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed right-0 w-[50vw] pointer-events-none"
         style="top: 75px; height: 25px; z-index: 100;
                background: #5cc8e6;
                clip-path: inset(0 0 0 100%);
                animation: sliding-bar-rtl 2s linear infinite;
                animation-delay: 1s;">
    </div>
    <div class="fixed right-0 w-[50vw] pointer-events-none"
         style="top: 100px; height: 25px; z-index: 100;
                background: #E2725B;
                clip-path: inset(0 0 0 100%);
                animation: sliding-bar-rtl 2s linear infinite;
                animation-delay: 1s;">
    </div>

    <!-- ═══ Sunburst background (radial composition) ═══ -->
    <div class="fixed inset-0 pointer-events-none z-0 flex items-center justify-center opacity-[0.06]">
      <svg viewBox="0 0 800 800" class="w-[150vmax] h-[150vmax]" style="animation: disco-rotate 120s linear infinite;">
        <g fill="#FFD700">
          {Array.from({ length: 24 }).map((_, i) => (
            <rect x="399" y="0" width="2" height="400"
                  transform={`rotate(${i * 15} 400 400)`} />
          ))}
        </g>
      </svg>
    </div>

    <!-- ═══ Floating sparkles (mouse-parallax depth layers) ═══ -->
    <div id="sparkle-field" class="fixed inset-0 pointer-events-none z-[1] overflow-hidden">
      <!-- Layer 1: slow/far sparkles -->
      <div class="sparkle-layer" data-depth="0.02">
        <svg class="sparkle" style="top: 12%; left: 8%; animation-delay: 0s;" viewBox="0 0 24 24" width="14" height="14">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700" />
        </svg>
        <svg class="sparkle" style="top: 45%; left: 85%; animation-delay: 1.2s;" viewBox="0 0 24 24" width="10" height="10">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FF007F" />
        </svg>
        <svg class="sparkle" style="top: 78%; left: 22%; animation-delay: 2.4s;" viewBox="0 0 24 24" width="12" height="12">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#40E0D0" />
        </svg>
      </div>
      <!-- Layer 2: medium sparkles -->
      <div class="sparkle-layer" data-depth="0.05">
        <svg class="sparkle" style="top: 25%; left: 72%; animation-delay: 0.7s;" viewBox="0 0 24 24" width="18" height="18">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700" />
        </svg>
        <svg class="sparkle" style="top: 65%; left: 15%; animation-delay: 1.8s;" viewBox="0 0 24 24" width="16" height="16">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#BCC6CC" />
        </svg>
        <svg class="sparkle" style="top: 88%; left: 65%; animation-delay: 3.1s;" viewBox="0 0 24 24" width="13" height="13">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FF007F" />
        </svg>
      </div>
      <!-- Layer 3: close/fast sparkles -->
      <div class="sparkle-layer" data-depth="0.1">
        <svg class="sparkle" style="top: 8%; left: 55%; animation-delay: 0.4s;" viewBox="0 0 24 24" width="22" height="22">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700" />
        </svg>
        <svg class="sparkle" style="top: 52%; left: 42%; animation-delay: 2.0s;" viewBox="0 0 24 24" width="20" height="20">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#5D3FD3" />
        </svg>
      </div>
    </div>

    <style>
      .sparkle-layer {
        position: absolute;
        inset: 0;
        transition: transform 0.15s ease-out;
      }
      .sparkle {
        position: absolute;
        animation: sparkle 3s ease-in-out infinite;
      }
    </style>

    <main class="relative z-10 max-w-[791px] mx-auto px-phi-lg py-phi-3xl space-y-phi-2xl">

      <!-- ═══ Disco Ball Hero ═══ -->
      <header class="text-center space-y-phi-lg">
        <!-- Mini disco ball motif -->
        <div class="mx-auto w-[89px] h-[89px] rounded-full relative"
             style="background: conic-gradient(from 0deg, #BCC6CC, #FFD700, #BCC6CC, #5D3FD3, #BCC6CC, #FF007F, #BCC6CC, #FFD700);
                    animation: disco-rotate 8s linear infinite;
                    box-shadow: 0 0 34px hsl(45, 100%, 50% / 0.4), 0 0 55px hsl(280, 60%, 50% / 0.2);">
          <!-- Facet grid overlay -->
          <div class="absolute inset-0 rounded-full opacity-40"
               style="background:
                 repeating-linear-gradient(0deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px),
                 repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px);">
          </div>
        </div>

        <!-- Purpose statement -->
        <p class="text-phi-md font-medium tracking-widest text-disco-gold uppercase"
           style="font-family: 'Poppins', sans-serif;">
          You're invited to celebrate
        </p>

        <!-- Date — hero display, 70s style -->
        <h1 class="text-warm-cream leading-none"
            style="font-family: 'Righteous', sans-serif;
                   font-size: clamp(2.8rem, 9vw, var(--font-size-phi-hero));
                   text-shadow:
                     3px 3px 0 #FF007F,
                     6px 6px 0 #483D8B;
                   letter-spacing: 0.02em;">
          July 11th, 2026
        </h1>

        <!-- Time -->
        <p class="text-phi-xl font-bold text-hot-pink"
           style="font-family: 'Righteous', sans-serif;
                  text-shadow: 2px 2px 0 hsl(270, 60%, 35% / 0.6);">
          6:00 PM
        </p>

        <!-- Location -->
        <p class="text-phi-md text-metallic-silver">
          The Design Studio, 742 Evergreen Terrace
        </p>
      </header>

      <!-- ═══ Disco stripe band ═══ -->
      <div class="disco-stripes w-full rounded-sm overflow-hidden" style="height: 21px;">
        <div class="h-full flex">
          <div class="flex-1" style="background: #FFD700;"></div>
          <div class="flex-1" style="background: #FF007F;"></div>
          <div class="flex-1" style="background: #483D8B;"></div>
          <div class="flex-1" style="background: #40E0D0;"></div>
          <div class="flex-1" style="background: #BCC6CC;"></div>
          <div class="flex-1" style="background: #CC5500;"></div>
          <div class="flex-1" style="background: #FFD700;"></div>
        </div>
      </div>

      <!-- ═══ 62/38 Golden Ratio Layout ═══ -->
      <div class="grid gap-phi-xl" style="grid-template-columns: 1fr 0.618fr;">

        <!-- 62% — Map with groovy frame -->
        <section class="relative">
          <div class="rounded-xl overflow-hidden relative"
               style="aspect-ratio: 1.618 / 1;
                      border: 3px solid #FFD700;
                      box-shadow: var(--shadow-elevation-medium), 0 0 21px hsl(45, 100%, 50% / 0.15);">
            <iframe
              class="w-full h-full"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.019112498507!2d-122.41941548468204!3d37.77492977975892!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80858064b1e8d1b9%3A0x4a83ab0e2e0fcc!2sSan%20Francisco%2C%20CA!5e0!3m2!1sen!2sus!4v1"
            ></iframe>
            <!-- Gradient shine overlay (near-zero GPU cost) -->
            <div class="absolute inset-0 pointer-events-none rounded-xl"
                 style="background: linear-gradient(135deg, rgba(255,215,0,0.08) 0%, transparent 50%, rgba(255,0,127,0.05) 100%);">
            </div>
          </div>
        </section>

        <!-- 38% — Actions panel -->
        <section class="flex flex-col gap-phi-lg justify-center">
          <!-- RSVP Button — disco gold with layered shadow -->
          <button
            id="rsvp-btn"
            class="w-full px-phi-xl py-phi-md text-pop-black rounded-xl text-phi-base font-bold
                   uppercase tracking-widest cursor-pointer transition-all duration-150"
            style="font-family: 'Righteous', sans-serif;
                   background: linear-gradient(135deg, #FFD700, #E1AD01);
                   border: 3px solid #B7410E;
                   box-shadow: 4px 4px 0 #FF007F, 0 0 13px hsl(45, 100%, 50% / 0.2);
                   min-height: 55px;"
            onmouseenter="this.style.boxShadow='var(--glow-dual), 4px 4px 0 #FF007F'"
            onmouseleave="this.style.boxShadow='4px 4px 0 #FF007F, 0 0 13px hsl(45, 100%, 50% / 0.2)'"
          >
            RSVP
          </button>

          <!-- Calendar Link -->
          <a
            id="cal-btn"
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Birthday+Celebration&dates=20260711T220000Z/20260712T030000Z&details=You%27re+invited+to+a+celebration+of+creativity%2C+friendship%2C+and+another+trip+around+the+sun.&location=The+Design+Studio%2C+742+Evergreen+Terrace&ctz=America/New_York"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Add this event to your Google Calendar"
            class="inline-flex items-center justify-center gap-phi-sm w-full px-phi-xl py-phi-md
                   text-turquoise rounded-xl text-phi-base font-bold uppercase tracking-widest
                   no-underline transition-all duration-150 cursor-pointer"
            style="font-family: 'Poppins', sans-serif;
                   background: rgba(64, 224, 208, 0.08);
                   border: 3px solid #40E0D0;
                   box-shadow: 4px 4px 0 #483D8B;
                   min-height: 55px;"
            onmouseenter="this.style.boxShadow='var(--glow-dual), 4px 4px 0 #483D8B'"
            onmouseleave="this.style.boxShadow='4px 4px 0 #483D8B'"
          >
            <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Save the Date
          </a>
        </section>
      </div>

      <!-- ═══ Disco stripe band (thin, reversed) ═══ -->
      <div class="disco-stripes w-full rounded-sm overflow-hidden" style="height: 8px;">
        <div class="h-full flex">
          <div class="flex-1" style="background: #CC5500;"></div>
          <div class="flex-1" style="background: #BCC6CC;"></div>
          <div class="flex-1" style="background: #40E0D0;"></div>
          <div class="flex-1" style="background: #483D8B;"></div>
          <div class="flex-1" style="background: #FF007F;"></div>
          <div class="flex-1" style="background: #FFD700;"></div>
        </div>
      </div>

      <!-- ═══ Footer ═══ -->
      <footer class="text-phi-sm text-center space-y-phi-xs" style="color: hsl(270, 30%, 55%);">
        <p>Astro + Tailwind 4 + Cloudflare Pages</p>
        <p id="runtime-info"></p>
      </footer>
    </main>

    <!-- ═══ RSVP Modal ═══ -->
    <div id="rsvp-modal" class="fixed inset-0 flex items-center justify-center p-phi-lg hidden z-50"
         style="background: rgba(26, 10, 46, 0.85); backdrop-filter: blur(4px);">
      <div class="rounded-2xl p-phi-2xl max-w-[489px] w-full space-y-phi-lg relative overflow-hidden"
           style="background: linear-gradient(160deg, #2d1254, #1a0a2e);
                  border: 3px solid #FFD700;
                  box-shadow: var(--shadow-elevation-high), 0 0 34px hsl(45, 100%, 50% / 0.15);">
        <!-- Shine overlay on modal -->
        <div class="absolute inset-0 pointer-events-none"
             style="background: radial-gradient(ellipse at 30% 20%, rgba(255,215,0,0.06), transparent 60%);"></div>

        <h2 class="text-phi-xl text-disco-gold relative"
            style="font-family: 'Righteous', sans-serif;
                   text-shadow: 2px 2px 0 hsl(300, 100%, 40% / 0.4);">
          RSVP
        </h2>
        <form id="rsvp-form" class="space-y-phi-md flex flex-col relative">
          <input
            name="name"
            type="text"
            placeholder="Your name"
            required
            class="w-full px-phi-md py-phi-sm rounded-lg text-phi-base text-warm-cream
                   placeholder-metallic-silver/50 focus:outline-none transition-colors"
            style="background: rgba(255,255,255,0.06);
                   border: 2px solid hsl(270, 30%, 40%);
                   caret-color: #FFD700;"
            onfocus="this.style.borderColor='#FFD700'"
            onblur="this.style.borderColor='hsl(270, 30%, 40%)'"
          />
          <textarea
            name="message"
            placeholder="A brief message (optional)"
            rows="3"
            class="w-full px-phi-md py-phi-sm rounded-lg text-phi-base text-warm-cream
                   placeholder-metallic-silver/50 resize-none focus:outline-none transition-colors"
            style="background: rgba(255,255,255,0.06);
                   border: 2px solid hsl(270, 30%, 40%);"
            onfocus="this.style.borderColor='#FFD700'"
            onblur="this.style.borderColor='hsl(270, 30%, 40%)'"
          ></textarea>
          <fieldset class="flex gap-phi-xl text-warm-cream">
            <label class="flex items-center gap-phi-sm cursor-pointer">
              <input type="radio" name="attending" value="yes" required
                     class="w-[18px] h-[18px]" style="accent-color: #FFD700;" />
              <span class="font-medium">I'll be there</span>
            </label>
            <label class="flex items-center gap-phi-sm cursor-pointer">
              <input type="radio" name="attending" value="no"
                     class="w-[18px] h-[18px]" style="accent-color: #FF007F;" />
              <span class="font-medium">Can't make it</span>
            </label>
          </fieldset>
          <div class="flex gap-phi-md pt-phi-sm">
            <button type="submit"
                    class="px-phi-xl py-phi-sm text-pop-black rounded-lg font-bold uppercase
                           tracking-wider cursor-pointer transition-all"
                    style="font-family: 'Righteous', sans-serif;
                           background: linear-gradient(135deg, #FFD700, #E1AD01);
                           border: 2px solid #B7410E;
                           box-shadow: 3px 3px 0 #FF007F;">
              Send
            </button>
            <button type="button" id="modal-close"
                    class="px-phi-xl py-phi-sm rounded-lg font-medium cursor-pointer transition-colors"
                    style="color: hsl(270, 30%, 65%);
                           border: 2px solid hsl(270, 30%, 35%);
                           background: transparent;"
                    onmouseenter="this.style.borderColor='hsl(270, 30%, 55%)'"
                    onmouseleave="this.style.borderColor='hsl(270, 30%, 35%)'">
              Cancel
            </button>
          </div>
        </form>
        <div id="rsvp-success" class="hidden text-center space-y-phi-lg py-phi-xl relative">
          <!-- Mini sparkle on success -->
          <svg class="mx-auto mb-phi-sm" width="34" height="34" viewBox="0 0 24 24">
            <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700"
                     style="animation: sparkle 1.5s ease-in-out infinite;" />
          </svg>
          <p class="text-phi-lg text-disco-gold" style="font-family: 'Righteous', sans-serif;">
            Far out!
          </p>
          <p class="text-metallic-silver">Your response has been recorded.</p>
          <button id="success-close"
                  class="px-phi-xl py-phi-sm text-turquoise rounded-lg font-medium cursor-pointer transition-colors"
                  style="border: 2px solid #40E0D0;"
                  onmouseenter="this.style.background='rgba(64,224,208,0.1)'"
                  onmouseleave="this.style.background='transparent'">
            Close
          </button>
        </div>
      </div>
    </div>

    <!-- ═══ Responsive ═══ -->
    <style>
      @media (max-width: 640px) {
        [style*="grid-template-columns: 1fr 0.618fr"] {
          grid-template-columns: 1fr !important;
        }
      }
    </style>

    <script>
      // ── Mouse parallax on sparkle layers (desktop only) ──
      const hasHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (hasHover && !prefersReducedMotion) {
        const layers = document.querySelectorAll('.sparkle-layer');
        let ticking = false;

        document.addEventListener('mousemove', (e) => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const cx = e.clientX - window.innerWidth / 2;
              const cy = e.clientY - window.innerHeight / 2;
              layers.forEach((layer) => {
                const depth = parseFloat((layer as HTMLElement).dataset.depth || '0');
                (layer as HTMLElement).style.transform =
                  `translate3d(${cx * depth}px, ${cy * depth}px, 0)`;
              });
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      // ── RSVP Modal ──
      const modal = document.getElementById('rsvp-modal')!;
      const form = document.getElementById('rsvp-form') as HTMLFormElement;
      const success = document.getElementById('rsvp-success')!;

      document.getElementById('rsvp-btn')!.addEventListener('click', () => {
        modal.classList.remove('hidden');
      });

      document.getElementById('modal-close')!.addEventListener('click', () => {
        modal.classList.add('hidden');
      });

      document.getElementById('success-close')!.addEventListener('click', () => {
        modal.classList.add('hidden');
        form.classList.remove('hidden');
        success.classList.add('hidden');
        form.reset();
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.add('hidden');
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));

        try {
          const res = await fetch('/api/rsvp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const result = await res.json();
          console.log('RSVP response:', result);
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } catch (err) {
          console.error('RSVP error:', err);
          alert('Something went wrong. Please try again.');
        }
      });

      // ── Runtime info ──
      document.getElementById('runtime-info')!.textContent =
        `Rendered ${typeof globalThis.caches !== 'undefined' ? 'on Cloudflare Workers (edge)' : 'locally (dev server)'}`;
    </script>
  </body>
</html>
