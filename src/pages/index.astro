---
import '../styles/global.css'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>You're Invited</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Righteous&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen overflow-x-hidden relative"
        style="font-family: 'Poppins', sans-serif;
               background: #f8f3e8;">


    <!-- ═══ Disco ball (dead center, behind everything) ═══ -->
    <div class="fixed inset-0 flex items-center justify-center pointer-events-none" style="z-index: -1;">
      <img src="/disco-ball.gif" alt="" class="w-[600px] h-[600px] object-cover" style="opacity: 0.7;" />
    </div>

    <!-- ═══ Sunburst background (radial composition) ═══ -->
    <div class="fixed inset-0 pointer-events-none z-0 flex items-center justify-center opacity-[0.06]">
      <svg viewBox="0 0 800 800" class="w-[150vmax] h-[150vmax]" style="animation: disco-rotate 120s linear infinite;">
        <g fill="#CC5500">
          {Array.from({ length: 24 }).map((_, i) => (
            <rect x="399" y="0" width="2" height="400"
                  transform={`rotate(${i * 15} 400 400)`} />
          ))}
        </g>
      </svg>
    </div>

    <!-- ═══ Floating sparkles (mouse-parallax depth layers) ═══ -->
    <div id="sparkle-field" class="fixed inset-0 pointer-events-none z-[1] overflow-hidden">
      <!-- Layer 1: slow/far sparkles -->
      <div class="sparkle-layer" data-depth="0.02">
        <svg class="sparkle" style="top: 12%; left: 8%; animation-delay: 0s;" viewBox="0 0 24 24" width="14" height="14">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700" />
        </svg>
        <svg class="sparkle" style="top: 45%; left: 85%; animation-delay: 1.2s;" viewBox="0 0 24 24" width="10" height="10">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FF007F" />
        </svg>
        <svg class="sparkle" style="top: 78%; left: 22%; animation-delay: 2.4s;" viewBox="0 0 24 24" width="12" height="12">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#40E0D0" />
        </svg>
      </div>
      <!-- Layer 2: medium sparkles -->
      <div class="sparkle-layer" data-depth="0.05">
        <svg class="sparkle" style="top: 25%; left: 72%; animation-delay: 0.7s;" viewBox="0 0 24 24" width="18" height="18">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700" />
        </svg>
        <svg class="sparkle" style="top: 65%; left: 15%; animation-delay: 1.8s;" viewBox="0 0 24 24" width="16" height="16">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#BCC6CC" />
        </svg>
        <svg class="sparkle" style="top: 88%; left: 65%; animation-delay: 3.1s;" viewBox="0 0 24 24" width="13" height="13">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FF007F" />
        </svg>
      </div>
      <!-- Layer 3: close/fast sparkles -->
      <div class="sparkle-layer" data-depth="0.1">
        <svg class="sparkle" style="top: 8%; left: 55%; animation-delay: 0.4s;" viewBox="0 0 24 24" width="22" height="22">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#FFD700" />
        </svg>
        <svg class="sparkle" style="top: 52%; left: 42%; animation-delay: 2.0s;" viewBox="0 0 24 24" width="20" height="20">
          <polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" fill="#5D3FD3" />
        </svg>
      </div>
    </div>

    <style>
      .bar-fade-right {}
      .bar-fade-left {}
      #rsvp-btn:hover .rsvp-shine {
        animation: shine-sweep-reverse 0.6s ease-in-out forwards !important;
      }
      .sparkle-layer {
        position: absolute;
        inset: 0;
        transition: transform 0.15s ease-out;
      }
      .sparkle {
        position: absolute;
        animation: sparkle 3s ease-in-out infinite;
      }
    </style>

    <main class="relative z-10 max-w-[791px] mx-auto px-phi-lg py-phi-3xl">

      <!-- ═══ Disco Ball Hero ═══ -->
      <header class="text-center space-y-phi-lg flex flex-col justify-end" style="min-height: 0;">
        <!-- Mini disco ball motif (hidden for now)
        <div class="mx-auto w-[89px] h-[89px] rounded-full relative"
             style="background: conic-gradient(from 0deg, #BCC6CC, #FFD700, #BCC6CC, #5D3FD3, #BCC6CC, #FF007F, #BCC6CC, #FFD700);
                    animation: disco-rotate 8s linear infinite;
                    box-shadow: 0 0 34px hsl(45, 100%, 50% / 0.4), 0 0 55px hsl(280, 60%, 50% / 0.2);">
          <div class="absolute inset-0 rounded-full opacity-40"
               style="background:
                 repeating-linear-gradient(0deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px),
                 repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px);">
          </div>
        </div>
        -->

        <!-- Purpose statement -->
        <svg viewBox="0 0 500 250" class="w-full max-w-[500px] mx-auto overflow-visible" style="margin-top: 120px;">
          <defs>
            <path id="text-arc" d="M 30,220 A 220,220 0 0,1 470,220" fill="none" />
          </defs>
          <text style="font-family: 'Poppins', sans-serif; font-size: 24px; font-weight: 500;
                       letter-spacing: 0.15em; text-transform: uppercase;"
                fill="#FFD700">
            <textPath href="#text-arc" startOffset="50%" text-anchor="middle">
              Let's celebrate Alina's first year of life!
            </textPath>
          </text>
        </svg>



      </header>

      <!-- ═══ Stripe animation panel (in-flow) ═══ -->
      <div class="relative w-screen -ml-phi-lg" style="height: 187px; left: 50%; transform: translateX(-50%);">
        <!-- Left bars -->
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 0; height: 7px; background: #e62e2e; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 7px; height: 20px; background: #f0e6c8; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 27px; height: 10px; background: #e85d20; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 37px; height: 17px; background: #f0e6c8; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 54px; height: 13px; background: #f0a818; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 67px; height: 14px; background: #f0e6c8; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 81px; height: 16px; background: #5cb832; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 97px; height: 11px; background: #f0e6c8; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 108px; height: 19px; background: #2480c0; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 127px; height: 8px; background: #f0e6c8; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 135px; height: 22px; background: #3b3fa0; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 157px; height: 5px; background: #f0e6c8; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute left-0 w-[50vw] bar-fade-right" style="top: 162px; height: 25px; background: #d03890; clip-path: inset(0 100% 0 0); animation: sliding-bar 2s linear forwards; animation-delay: 1s;"></div>

        <!-- Right bars -->
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 0; height: 7px; background: #e62e2e; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 7px; height: 20px; background: #f0e6c8; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 27px; height: 10px; background: #e85d20; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 37px; height: 17px; background: #f0e6c8; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 54px; height: 13px; background: #f0a818; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 67px; height: 14px; background: #f0e6c8; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 81px; height: 16px; background: #5cb832; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 97px; height: 11px; background: #f0e6c8; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 108px; height: 19px; background: #2480c0; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 127px; height: 8px; background: #f0e6c8; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 135px; height: 22px; background: #3b3fa0; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 157px; height: 5px; background: #f0e6c8; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>
        <div class="absolute right-0 w-[50vw] bar-fade-left" style="top: 162px; height: 25px; background: #d03890; clip-path: inset(0 0 0 100%); animation: sliding-bar-rtl 2s linear forwards; animation-delay: 1s;"></div>

        <!-- Sliding text: left -->
        <div class="absolute pointer-events-none"
             style="top: 50%; left: 50%;
                    transform: translate(-100%, -50%) translateX(-50vw);
                    z-index: 1;
                    animation: ride-in-date 2s linear forwards; animation-delay: 1s;
                    font-family: 'Righteous', sans-serif;
                    font-size: clamp(2.8rem, 9vw, var(--font-size-phi-hero));
                    color: #FFFFFF; white-space: nowrap; letter-spacing: 0.02em;
                    text-shadow: 4px 4px 0 #483D8B; line-height: 1;">
          July 11th
        </div>

        <!-- Sliding text: right -->
        <div class="absolute pointer-events-none"
             style="top: 50%; right: 50%;
                    transform: translate(100%, -50%) translateX(50vw);
                    z-index: 1;
                    animation: ride-in-date-rtl 2s linear forwards; animation-delay: 1s;
                    font-family: 'Righteous', sans-serif;
                    font-size: clamp(2.8rem, 9vw, var(--font-size-phi-hero));
                    color: #FFFFFF; white-space: nowrap; letter-spacing: 0.02em;
                    text-shadow: 4px 4px 0 #483D8B; line-height: 1;">
          3-6pm
        </div>
      </div>

      <!-- ═══ 62/38 Golden Ratio Layout ═══ -->
      <div class="grid gap-phi-xl content-reveal justify-center" style="grid-template-columns: auto auto;
           opacity: 0; animation: reveal-up 0.8s ease-out 3s forwards;">

        <!-- 62% — Map with groovy frame -->
        <section class="relative" style="width: 187px;">
          <div class="rounded-xl overflow-hidden relative"
               style="width: 187px; height: 187px;
                      border: 3px solid #483D8B;
                      box-shadow: var(--shadow-elevation-medium), 0 0 21px hsl(45, 100%, 50% / 0.15);">
            <iframe
              class="w-full h-full"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q=3220+Alabama+CT,+Houston,+TX+77027&output=embed"
            ></iframe>
          </div>
        </section>

        <!-- 38% — Actions panel -->
        <section class="flex flex-col gap-phi-lg justify-center">
          <!-- RSVP Button — disco gold with layered shadow -->
          <button
            id="rsvp-btn"
            class="w-full px-phi-xl py-phi-md rounded-xl text-phi-base font-bold
                   uppercase tracking-widest cursor-pointer transition-all duration-300 relative overflow-hidden"
            style="font-family: 'Righteous', sans-serif;
                   background: #faf7f2;
                   color: #483D8B;
                   border: 3px solid #483D8B;
                   box-shadow: 4px 4px 0 #483D8B;
                   min-height: 55px;"
            onmouseenter="this.style.boxShadow='var(--glow-dual), 4px 4px 0 #483D8B'"
            onmouseleave="this.style.boxShadow='4px 4px 0 #483D8B'"
          >
            <!-- Default state -->
            <span id="rsvp-btn-default">RSVP</span>
            <!-- Submitted state -->
            <div id="rsvp-btn-status" class="hidden text-left space-y-phi-xs" style="font-family: 'Poppins', sans-serif;">
              <div class="flex items-center justify-between">
                <span id="rsvp-status-name" class="text-phi-base font-semibold truncate"></span>
                <span id="rsvp-status-badge" class="text-phi-sm font-bold uppercase tracking-wider shrink-0 ml-phi-sm px-phi-sm py-phi-xs rounded" style="background: #f0e6c8;"></span>
              </div>
              <p id="rsvp-status-message" class="text-phi-sm font-normal normal-case tracking-normal opacity-70 truncate"></p>
            </div>
            <div class="rsvp-shine absolute inset-0 pointer-events-none rounded-xl"
                 style="background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.5) 50%, transparent 60%);
                        background-size: 200% 100%;
                        animation: shine-sweep 0.6s ease-in-out 3.8s forwards;">
            </div>
          </button>

          <!-- Calendar Link -->
          <a
            id="cal-btn"
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Birthday+Celebration&dates=20260711T220000Z/20260712T030000Z&details=You%27re+invited+to+a+celebration+of+creativity%2C+friendship%2C+and+another+trip+around+the+sun.&location=3220+Alabama+CT%2C+Houston%2C+TX+77027&ctz=America/New_York"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Add this event to your Google Calendar"
            class="inline-flex items-center justify-center gap-phi-sm w-full px-phi-xl py-phi-md
                   rounded-xl text-phi-base font-bold uppercase tracking-widest text-[#483D8B]
                   no-underline transition-all duration-150 cursor-pointer"
            style="font-family: 'Poppins', sans-serif;
                   background: #faf7f2;
                   border: 3px solid #483D8B;
                   box-shadow: 4px 4px 0 #483D8B;
                   min-height: 55px;"
            onmouseenter="this.style.boxShadow='var(--glow-dual), 4px 4px 0 #483D8B'"
            onmouseleave="this.style.boxShadow='4px 4px 0 #483D8B'"
          >
            <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Add to Calendar
          </a>
        </section>
      </div>


      <!-- ═══ Footer ═══ -->
    </main>

    <!-- ═══ RSVP Modal ═══ -->
    <div id="rsvp-modal" class="fixed inset-0 flex items-center justify-center p-phi-lg hidden z-50"
         style="background: rgba(26, 10, 46, 0.85); backdrop-filter: blur(4px);">
      <div class="rounded-2xl p-phi-2xl max-w-[489px] w-full space-y-phi-lg relative overflow-hidden"
           style="background: linear-gradient(160deg, #2d1254, #1a0a2e);
                  border: 3px solid #FFD700;
                  box-shadow: var(--shadow-elevation-high), 0 0 34px hsl(45, 100%, 50% / 0.15);">
        <!-- Shine overlay on modal -->
        <div class="absolute inset-0 pointer-events-none"
             style="background: radial-gradient(ellipse at 30% 20%, rgba(255,215,0,0.06), transparent 60%);"></div>

        <h2 class="text-phi-xl text-disco-gold relative"
            style="font-family: 'Righteous', sans-serif;
                   text-shadow: 2px 2px 0 hsl(300, 100%, 40% / 0.4);">
          RSVP
        </h2>
        <form id="rsvp-form" class="space-y-phi-md flex flex-col relative">
          <input
            name="name"
            type="text"
            placeholder="Your name"
            required
            class="w-full px-phi-md py-phi-sm rounded-lg text-phi-base text-warm-cream
                   placeholder-metallic-silver/50 focus:outline-none transition-colors"
            style="background: rgba(255,255,255,0.06);
                   border: 2px solid hsl(270, 30%, 40%);
                   caret-color: #FFD700;"
            onfocus="this.style.borderColor='#FFD700'"
            onblur="this.style.borderColor='hsl(270, 30%, 40%)'"
          />
          <textarea
            name="message"
            placeholder="A brief message (optional)"
            rows="3"
            class="w-full px-phi-md py-phi-sm rounded-lg text-phi-base text-warm-cream
                   placeholder-metallic-silver/50 resize-none focus:outline-none transition-colors"
            style="background: rgba(255,255,255,0.06);
                   border: 2px solid hsl(270, 30%, 40%);"
            onfocus="this.style.borderColor='#FFD700'"
            onblur="this.style.borderColor='hsl(270, 30%, 40%)'"
          ></textarea>
          <fieldset class="flex gap-phi-xl text-warm-cream">
            <label class="flex items-center gap-phi-sm cursor-pointer">
              <input type="radio" name="attending" value="yes" required
                     class="w-[18px] h-[18px]" style="accent-color: #FFD700;" />
              <span class="font-medium">I'll be there</span>
            </label>
            <label class="flex items-center gap-phi-sm cursor-pointer">
              <input type="radio" name="attending" value="no"
                     class="w-[18px] h-[18px]" style="accent-color: #FF007F;" />
              <span class="font-medium">Can't make it</span>
            </label>
          </fieldset>
          <div class="flex gap-phi-md pt-phi-sm">
            <button type="submit" id="rsvp-submit"
                    class="px-phi-xl py-phi-sm text-pop-black rounded-lg font-bold uppercase
                           tracking-wider transition-all disabled:opacity-40 disabled:cursor-not-allowed"
                    style="font-family: 'Righteous', sans-serif;
                           background: linear-gradient(135deg, #FFD700, #E1AD01);
                           border: 2px solid #B7410E;
                           box-shadow: 3px 3px 0 #FF007F;">
              Send
            </button>
            <button type="button" id="modal-close"
                    class="px-phi-xl py-phi-sm rounded-lg font-medium cursor-pointer transition-colors"
                    style="color: hsl(270, 30%, 65%);
                           border: 2px solid hsl(270, 30%, 35%);
                           background: transparent;"
                    onmouseenter="this.style.borderColor='hsl(270, 30%, 55%)'"
                    onmouseleave="this.style.borderColor='hsl(270, 30%, 35%)'">
              Cancel
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- ═══ Responsive ═══ -->
    <style>
      @media (max-width: 640px) {
        [style*="grid-template-columns: 1fr 0.618fr"] {
          grid-template-columns: 1fr !important;
        }
      }
    </style>

    <script>
      // ── Mouse parallax on sparkle layers (desktop only) ──
      const hasHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (hasHover && !prefersReducedMotion) {
        const layers = document.querySelectorAll('.sparkle-layer');
        let ticking = false;

        document.addEventListener('mousemove', (e) => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const cx = e.clientX - window.innerWidth / 2;
              const cy = e.clientY - window.innerHeight / 2;
              layers.forEach((layer) => {
                const depth = parseFloat((layer as HTMLElement).dataset.depth || '0');
                (layer as HTMLElement).style.transform =
                  `translate3d(${cx * depth}px, ${cy * depth}px, 0)`;
              });
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      // ── RSVP Modal ──
      const modal = document.getElementById('rsvp-modal')!;
      const form = document.getElementById('rsvp-form') as HTMLFormElement;

      // ── RSVP button state from localStorage ──
      const rsvpBtn = document.getElementById('rsvp-btn')!;
      const rsvpDefault = document.getElementById('rsvp-btn-default')!;
      const rsvpStatus = document.getElementById('rsvp-btn-status')!;
      const rsvpName = document.getElementById('rsvp-status-name')!;
      const rsvpBadge = document.getElementById('rsvp-status-badge')!;
      const rsvpMessage = document.getElementById('rsvp-status-message')!;

      function showRsvpStatus() {
        const saved = localStorage.getItem('rsvp');
        if (!saved) return;
        const data = JSON.parse(saved);
        rsvpDefault.classList.add('hidden');
        rsvpStatus.classList.remove('hidden');
        rsvpName.textContent = data.name;
        rsvpBadge.textContent = data.attending === 'yes' ? 'Going' : 'Not going';
        rsvpBadge.style.color = data.attending === 'yes' ? '#5cb832' : '#e62e2e';
        const msg = data.message || '';
        rsvpMessage.textContent = msg.length > 100 ? msg.slice(0, 100) + '…' : msg;
        rsvpMessage.classList.toggle('hidden', !msg);
      }

      showRsvpStatus();

      const submitBtn = document.getElementById('rsvp-submit') as HTMLButtonElement;
      let savedSnapshot = '';

      function getCurrentFormData() {
        return JSON.stringify({
          name: (form.elements.namedItem('name') as HTMLInputElement).value,
          message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
          attending: (form.querySelector('input[name="attending"]:checked') as HTMLInputElement)?.value || '',
        });
      }

      function updateSubmitState() {
        const current = getCurrentFormData();
        const nameVal = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
        submitBtn.disabled = !nameVal || current === savedSnapshot;
      }

      form.addEventListener('input', updateSubmitState);
      form.addEventListener('change', updateSubmitState);

      rsvpBtn.addEventListener('click', () => {
        const saved = localStorage.getItem('rsvp');
        if (saved) {
          const data = JSON.parse(saved);
          (form.elements.namedItem('name') as HTMLInputElement).value = data.name || '';
          (form.elements.namedItem('message') as HTMLTextAreaElement).value = data.message || '';
          const radio = form.querySelector(`input[name="attending"][value="${data.attending}"]`) as HTMLInputElement;
          if (radio) radio.checked = true;
        }
        savedSnapshot = getCurrentFormData();
        submitBtn.disabled = true;
        modal.classList.remove('hidden');
      });

      document.getElementById('modal-close')!.addEventListener('click', () => {
        modal.classList.add('hidden');
      });


      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.add('hidden');
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));

        try {
          const res = await fetch('/api/rsvp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const result = await res.json();
          console.log('RSVP response:', result);
          localStorage.setItem('rsvp', JSON.stringify(data));
          showRsvpStatus();
          modal.classList.add('hidden');
          if (data.attending === 'yes') burstStars();
        } catch (err) {
          console.error('RSVP error:', err);
          alert('Something went wrong. Please try again.');
        }
      });

      // ── Star burst celebration (on "Going" submit) ──
      function burstStars() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const btnRect = rsvpBtn.getBoundingClientRect();
        const cx = btnRect.left + btnRect.width / 2;
        const cy = btnRect.top;
        const colors = ['#FFD700', '#FF007F', '#40E0D0', '#e62e2e', '#5cb832', '#3b3fa0', '#e85d20', '#f0a818'];
        const count = 14;

        for (let i = 0; i < count; i++) {
          const star = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
          star.setAttribute('viewBox', '0 0 24 24');
          const size = 10 + Math.random() * 16;
          star.style.cssText = `
            position: fixed;
            left: ${cx - size / 2}px;
            top: ${cy}px;
            width: ${size}px;
            height: ${size}px;
            z-index: 9999;
            pointer-events: none;
            --burst-x: ${(Math.random() - 0.5) * 160}px;
            --burst-peak: ${-60 - Math.random() * 100}px;
            animation: star-burst ${0.6 + Math.random() * 0.4}s ease-out forwards;
            animation-delay: ${Math.random() * 0.15}s;
          `;
          const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
          poly.setAttribute('points', '12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5');
          poly.setAttribute('fill', colors[Math.floor(Math.random() * colors.length)]);
          star.appendChild(poly);
          document.body.appendChild(star);
          star.addEventListener('animationend', () => star.remove());
        }
      }

    </script>
  </body>
</html>
