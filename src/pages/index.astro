  <body class="min-h-screen overflow-x-hidden relative"
        style="font-family: 'Righteous', sans-serif;
               background: #6BB8FF;">



    <!-- ═══ Sunburst background (multi-color rays, parallax back layer) ═══ -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" style="z-index: -2;">
    <div id="sunburst-container" class="sunburst-bg sparkle-layer w-full h-full flex items-center justify-center overflow-visible"
         data-depth="0.008"
         style="opacity: 1; transition: transform 1.5s ease-in-out;">
      <svg id="sunburst-svg" viewBox="0 0 1000 1000" style="width: 400vmax; height: 400vmax; border-radius: 50%; animation: disco-rotate 180s linear infinite; flex-shrink: 0; transition: transform 1.5s ease-in-out, width 1.5s ease-in-out, height 1.5s ease-in-out;">
        {(() => {
          const colors = ['#C0E4FF', '#B0F0FF', '#CCE4FF', '#FFE8FF', '#C0E4FF', '#D0F0FF', '#CCE4FF', '#B8ECFF', '#B0F0FF', '#FFE8FF', '#D0F0FF', '#C0E4FF'];
          const rays = [];
          const count = 36;
          const angleStep = 360 / count;
          const cx = 500, cy = 500, r = 600;
          for (let i = 0; i < count; i++) {
            const a1 = (i * angleStep - 90) * Math.PI / 180;
            const a2 = ((i + 1) * angleStep - 90) * Math.PI / 180;
            const x1 = cx + r * Math.cos(a1);
            const y1 = cy + r * Math.sin(a1);
            const x2 = cx + r * Math.cos(a2);
            const y2 = cy + r * Math.sin(a2);
            rays.push(
              <polygon
                points={`${cx},${cy} ${x1},${y1} ${x2},${y2}`}
                fill={colors[i % colors.length]}
              />
            );
          }
          return rays;
        })()}
        <!-- Center circle -->
      </svg>
    </div>
    </div>

    <!-- ═══ Corner clouds (stacked circles, tucked into corners) ═══ -->
    <div id="clouds-container" class="fixed inset-0 pointer-events-none" style="z-index: -1;">
