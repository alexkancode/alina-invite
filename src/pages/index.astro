        /* Reduce stripe panel height */
        .stripe-panel {
          margin-top: 50px !important;
          height: 120px !important;
        }

        /* Slide-in text on mobile */
        .slide-text {
          font-size: 50px !important;
          line-height: 1 !important;
          margin-top: 50px !important;
        }

        /* Arc text: behind content, centered, pushed down, fades out after reveal */
        .arc-text-svg, .disco-ball-scene {
          display: none !important;
        }
        .birthday-label {
          color: #483D8B !important;
          max-width: 90vw !important;
          position: absolute !important;
          top: 250px;
          left: 50%;
          transform: translateX(-50%);
          z-index: -1;
          opacity: 0.5;
          animation: fade-out-arc 0.6s ease-out 4.4s forwards !important;
        }


        /* Buttons full width on mobile */
        #rsvp-btn, #cal-btn {
          min-width: 250px;
        }

        /* Map matches button styling on mobile */
        .map-section {
          width: calc(100% - 103px) !important;
          max-width: none;
        }
        .map-section > div {
          width: 100% !important;
          height: 87px !important;
          box-shadow: 4px 4px 0 #483D8B !important;
        }

        /* Modal tighter padding on mobile */
        #rsvp-modal > div {
          padding: 21px !important;
          margin: 13px;
        }

        /* Smaller spacer on mobile */
        .stripe-content-spacer {
          height: 100px !important;
        }

        /* Reduce sunburst size */
        .sunburst-bg svg {
          width: 120vmax !important;
          height: 120vmax !important;
        }
      }
    </style>

    <script>
      // ── Mouse parallax on sparkle layers (desktop only) ──
      const hasHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (hasHover && !prefersReducedMotion) {
        const layers = document.querySelectorAll('.sparkle-layer');
        let ticking = false;

        document.addEventListener('mousemove', (e) => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const cx = e.clientX - window.innerWidth / 2;
              const cy = e.clientY - window.innerHeight / 2;
              layers.forEach((layer) => {
                const depth = parseFloat((layer as HTMLElement).dataset.depth || '0');
                (layer as HTMLElement).style.transform =
                  `translate3d(${cx * depth}px, ${cy * depth}px, 0)`;
              });
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      // ── RSVP Modal ──
      const modal = document.getElementById('rsvp-modal')!;
      const form = document.getElementById('rsvp-form') as HTMLFormElement;

      // ── RSVP button state from localStorage ──
      const rsvpBtn = document.getElementById('rsvp-btn')!;
      const rsvpDefault = document.getElementById('rsvp-btn-default')!;
      const rsvpStatus = document.getElementById('rsvp-btn-status')!;
      const rsvpName = document.getElementById('rsvp-status-name')!;
      const rsvpBadge = document.getElementById('rsvp-status-badge')!;
      const rsvpMessage = document.getElementById('rsvp-status-message')!;

      function showRsvpStatus() {
        const saved = localStorage.getItem('rsvp');
        if (!saved) return;
        const data = JSON.parse(saved);
        rsvpDefault.classList.add('hidden');
        rsvpStatus.classList.remove('hidden');
        rsvpName.textContent = data.name;
        rsvpBadge.textContent = data.attending === 'yes' ? 'Going' : 'Not going';
        rsvpBadge.style.color = '#8B2FC9';
        const msg = data.message || '';
        rsvpMessage.textContent = msg.length > 100 ? msg.slice(0, 100) + '…' : msg;
        rsvpMessage.classList.toggle('hidden', !msg);
      }

      showRsvpStatus();

      const submitBtn = document.getElementById('rsvp-submit') as HTMLButtonElement;
      let savedSnapshot = '';

      function getCurrentFormData() {
        return JSON.stringify({
          name: (form.elements.namedItem('name') as HTMLInputElement).value,
          message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
          attending: (form.querySelector('input[name="attending"]:checked') as HTMLInputElement)?.value || '',
        });
      }

      function updateSubmitState() {
        const current = getCurrentFormData();
        const nameVal = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
        submitBtn.disabled = !nameVal || current === savedSnapshot;
      }

      form.addEventListener('input', updateSubmitState);
      form.addEventListener('change', updateSubmitState);

      rsvpBtn.addEventListener('click', () => {
        const saved = localStorage.getItem('rsvp');
        if (saved) {
          const data = JSON.parse(saved);
          (form.elements.namedItem('name') as HTMLInputElement).value = data.name || '';
          (form.elements.namedItem('message') as HTMLTextAreaElement).value = data.message || '';
          const radio = form.querySelector(`input[name="attending"][value="${data.attending}"]`) as HTMLInputElement;
          if (radio) radio.checked = true;
        }
        savedSnapshot = getCurrentFormData();
        submitBtn.disabled = true;
        modal.classList.remove('hidden');
        document.body.classList.add('accent-pink');
      });

      document.getElementById('modal-close')!.addEventListener('click', () => {
        modal.classList.add('hidden');
        document.body.classList.remove('accent-pink');
      });


      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
          document.body.classList.remove('accent-pink');
        }
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(form));

        try {
          const res = await fetch('/api/rsvp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const result = await res.json();
          console.log('RSVP response:', result);
          localStorage.setItem('rsvp', JSON.stringify(data));
          showRsvpStatus();
          modal.classList.add('hidden');
          document.body.classList.remove('accent-pink');
          if (data.attending === 'yes') burstStars();
        } catch (err) {
          console.error('RSVP error:', err);
          alert('Something went wrong. Please try again.');
        }
      });

      // ── Star burst celebration (on "Going" submit) ──
      function burstStars() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const btnRect = rsvpBtn.getBoundingClientRect();
        const cx = btnRect.left + btnRect.width / 2;
        const cy = btnRect.top;
        const colors = ['#FFD700', '#FF007F', '#40E0D0', '#e62e2e', '#5cb832', '#3b3fa0', '#e85d20', '#f0a818'];
        const count = 14;

        for (let i = 0; i < count; i++) {
          const star = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
          star.setAttribute('viewBox', '0 0 24 24');
          const size = 10 + Math.random() * 16;
          star.style.cssText = `
            position: fixed;
            left: ${cx - size / 2}px;
            top: ${cy}px;
            width: ${size}px;
            height: ${size}px;
            z-index: 9999;
            pointer-events: none;
            --burst-x: ${(Math.random() - 0.5) * 160}px;
            --burst-peak: ${-60 - Math.random() * 100}px;
            animation: star-burst ${0.6 + Math.random() * 0.4}s ease-out forwards;
            animation-delay: ${Math.random() * 0.15}s;
          `;
          const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
          poly.setAttribute('points', '12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5');
          poly.setAttribute('fill', colors[Math.floor(Math.random() * colors.length)]);
          star.appendChild(poly);
          document.body.appendChild(star);
          star.addEventListener('animationend', () => star.remove());
        }
      }

      // ── Sparkle follow mode (tabled for now) ──

      // ── Build cartoon disco ball ──
      function buildDiscoBall(containerId: string, radius: number, tileSize: number) {
        const container = document.getElementById(containerId)!;
        const latStep = tileSize / radius;
        const gapFactor = 1.15;
        const photos = [
          '/alina/thumbs/IMG_0049.jpeg', '/alina/thumbs/IMG_0539.jpeg', '/alina/thumbs/IMG_0736.jpeg',
          '/alina/thumbs/IMG_7205.jpeg', '/alina/thumbs/IMG_7380.jpeg', '/alina/thumbs/IMG_8370.jpeg',
          '/alina/thumbs/IMG_8625.jpeg', '/alina/thumbs/IMG_9286.jpeg', '/alina/thumbs/IMG_9477.jpeg',
          '/alina/thumbs/IMG_9532.jpeg'
        ];
        let count = 0;

        for (let phi = latStep / 2; phi < Math.PI; phi += latStep) {
          const ringRadius = radius * Math.sin(phi);
          const numTiles = Math.max(2, Math.floor((2 * Math.PI * ringRadius) / (tileSize * gapFactor)));
          const lonStep = (2 * Math.PI) / numTiles;

          for (let i = 0; i < numTiles; i++) {
            const theta = i * lonStep;
            const tile = document.createElement('div');
            tile.className = 'mirror-tile';
            tile.style.width = tileSize + 'px';
            tile.style.height = tileSize + 'px';
            tile.style.left = -(tileSize / 2) + 'px';
            tile.style.top = -(tileSize / 2) + 'px';
            tile.style.transform =
              `rotateY(${(theta * 180) / Math.PI}deg) ` +
              `rotateX(${(phi * 180) / Math.PI - 90}deg) ` +
              `translateZ(${radius}px)`;
            if (Math.random() < 0.3) {
              // Iridescent tile — static gradient, parent rotation does shimmer
              tile.classList.add('iridescent');
            } else {
              // Photo tile
              tile.style.backgroundImage = `url('${photos[count % photos.length]}')`;
              tile.style.backgroundSize = 'cover';
              tile.style.backgroundPosition = 'center';
            }
            container.appendChild(tile);
            count++;
          }
        }
      }

      buildDiscoBall('discoBall', 130, 22);

      // ── Tile Match Game ──
      const TILE_PHOTOS = [
        '/alina/minigame/IMG_0049.jpeg', '/alina/minigame/IMG_0539.jpeg', '/alina/minigame/IMG_0736.jpeg',
        '/alina/minigame/IMG_7205.jpeg', '/alina/minigame/IMG_7380.jpeg', '/alina/minigame/IMG_8370.jpeg',
        '/alina/minigame/IMG_8625.jpeg', '/alina/minigame/IMG_9286.jpeg', '/alina/minigame/IMG_9477.jpeg',
        '/alina/minigame/IMG_9532.jpeg',
      ];
      const TILE_EMOJIS = ['🎈', '🎂', '🧁', '🎁', '🎀', '⭐', '🦋', '🌸', '🎵', '🍭', '🌈', '🎪'];
      const DIFFICULTY_CONFIG: Record<string, { pairs: number; cols: number }> = {
        easy:   { pairs: 6,  cols: 3 },
        medium: { pairs: 8,  cols: 4 },
        hard:   { pairs: 12, cols: 4 },
      };

      interface GameTile { id: number; pairId: number; emoji: string; el: HTMLElement; }

      const gameState = {
        phase: 'idle' as 'idle' | 'ready' | 'first_pick' | 'checking' | 'complete',
        tiles: [] as GameTile[],
        firstPick: null as GameTile | null,
        matchedPairs: new Set<number>(),
        moves: 0,
        startTime: 0,
        difficulty: 'medium',
        timerRaf: 0,
      };

      const gameModal   = document.getElementById('game-modal')!;
      const gameBoard    = document.getElementById('game-board')!;
      const gameMovesEl  = document.getElementById('game-moves')!;
      const gameTimerEl  = document.getElementById('game-timer')!;
      const gameScoreEl  = document.getElementById('game-score-display')!;
      const gameOverEl   = document.getElementById('game-over')!;
      const gameFinalEl  = document.getElementById('game-final-score')!;
      const gameNameRow  = document.getElementById('game-name-row')!;
      const gameNameInput = document.getElementById('game-player-name') as HTMLInputElement;
      const gameNameGreeting = document.getElementById('game-name-greeting')!;
      const gameSubmitBtn = document.getElementById('game-submit-score') as HTMLButtonElement;
      const gameSubmitStatus = document.getElementById('game-submit-status')!;
      const gameLeaderboardList = document.getElementById('game-leaderboard-list')!;

      let lastGameElapsed = 0;

      function getPlayerName(): string | null {
        const rsvp = localStorage.getItem('rsvp');
        if (rsvp) {
          try { return JSON.parse(rsvp).name || null; } catch { return null; }
        }
        return null;
      }

      async function fetchLeaderboard(difficulty: string) {
        try {
          const res = await fetch(`/api/leaderboard?difficulty=${difficulty}&limit=10`);
          if (!res.ok) throw new Error('fetch failed');
          const scores = await res.json() as Array<{ player: string; score: number; moves: number; time_ms: number }>;
          if (scores.length === 0) {
            gameLeaderboardList.innerHTML = '<p class="text-metallic-silver">No scores yet. Be the first!</p>';
            return;
          }

          const currentPlayer = getPlayerName() || gameNameInput.value.trim();
          const playerBest = currentPlayer
            ? scores.filter(s => s.player === currentPlayer).reduce((best, s) => Math.max(best, s.score), 0)
            : 0;

          let html = '';
          if (playerBest > 0) {
            html += `<div class="flex justify-between items-center py-1 mb-phi-xs" style="border-bottom: 2px solid rgba(255,215,0,0.25);">
              <span class="text-[#FFB6D9] text-phi-xs font-medium">Your best</span>
              <span class="text-[#FFB6D9] tabular-nums font-bold">${playerBest.toLocaleString()}</span>
            </div>`;
          }

          html += scores.map((s, i) => {
            const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `<span style="display:inline-block;width:1.3em;text-align:center;">${i + 1}</span>`;
            const isMe = currentPlayer && s.player === currentPlayer;
            const highlight = isMe ? 'color: #FFB6D9; font-weight: 600;' : '';
            return `<div class="flex justify-between items-center py-1" style="border-bottom: 1px solid rgba(255,255,255,0.05); ${highlight}">
              <span>${medal} ${s.player}</span>
              <span class="tabular-nums" style="${isMe ? 'color: #FFB6D9;' : 'color: #FFB6D9;'}">${s.score.toLocaleString()}</span>
            </div>`;
          }).join('');

          gameLeaderboardList.innerHTML = html;
        } catch {
          gameLeaderboardList.innerHTML = '<p class="text-metallic-silver">Could not load leaderboard</p>';
        }
      }

      async function submitScore() {
        const name = gameNameInput.value.trim();
        if (!name) {
          gameSubmitStatus.textContent = 'Please enter your name';
          gameSubmitStatus.style.color = '#FF007F';
          gameSubmitStatus.classList.remove('hidden');
          gameNameInput.focus();
          return;
        }

        gameSubmitBtn.disabled = true;
        gameSubmitBtn.textContent = 'Submitting...';
        gameSubmitStatus.classList.add('hidden');

        try {
          const res = await fetch('/api/leaderboard', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              player: name,
              moves: gameState.moves,
              timeMs: Math.round(lastGameElapsed),
              difficulty: gameState.difficulty,
            }),
          });

          if (!res.ok) {
            const err = await res.json().catch(() => ({ error: 'Unknown error' }));
            throw new Error(err.error || 'Submit failed');
          }

          const { score } = await res.json();
          gameSubmitStatus.textContent = `Score submitted: ${score.toLocaleString()}`;
          gameSubmitStatus.style.color = '#40E0D0';
          gameSubmitStatus.classList.remove('hidden');
          gameSubmitBtn.textContent = 'Submitted!';

          // Refresh leaderboard
          await fetchLeaderboard(gameState.difficulty);
        } catch (err: any) {
          gameSubmitStatus.textContent = err.message || 'Something went wrong';
          gameSubmitStatus.style.color = '#FF007F';
          gameSubmitStatus.classList.remove('hidden');
          gameSubmitBtn.disabled = false;
          gameSubmitBtn.textContent = 'Submit Score';
        }
      }

      function formatGameTime(ms: number): string {
        const s = Math.floor(ms / 1000);
        return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
      }

      function calcGameScore(moves: number, timeMs: number, pairs: number): number {
        const moveEff = pairs / moves;
        const timeEff = Math.min(1, 120_000 / timeMs);
        return Math.round((moveEff * 0.6 + timeEff * 0.4) * 10_000);
      }

      function shuffleArray<T>(arr: T[]): T[] {
        for (let i = arr.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
      }

      function startGame(difficulty: string) {
        const config = DIFFICULTY_CONFIG[difficulty] || DIFFICULTY_CONFIG.medium;
        gameState.difficulty = difficulty;
        gameState.moves = 0;
        gameState.matchedPairs.clear();
        gameState.firstPick = null;
        gameState.phase = 'ready';
        cancelAnimationFrame(gameState.timerRaf);
        gameOverEl.classList.add('hidden');
        gameScoreEl.textContent = 'Score: —';
        gameMovesEl.textContent = 'Moves: 0';
        gameTimerEl.textContent = '0:00';

        gameBoard.style.setProperty('--cols', String(config.cols));

        // Photos first, emoji fallback for any overflow
        const faces: Array<{ type: 'photo' | 'emoji'; src: string }> = [];
        for (let i = 0; i < config.pairs; i++) {
          if (i < TILE_PHOTOS.length) {
            faces.push({ type: 'photo', src: TILE_PHOTOS[i] });
          } else {
            faces.push({ type: 'emoji', src: TILE_EMOJIS[i - TILE_PHOTOS.length] });
          }
        }

        const pairIds = shuffleArray(
          Array.from({ length: config.pairs }, (_, i) => [i, i]).flat()
        );

        gameBoard.innerHTML = '';
        gameState.tiles = pairIds.map((pairId, id) => {
          const face = faces[pairId];
          const el = document.createElement('div');
          el.className = 'game-tile';
          el.dataset.id = String(id);
          const backContent = face.type === 'photo'
            ? `<div class="game-tile-back game-tile-photo"><img src="${face.src}" alt="" draggable="false" /></div>`
            : `<div class="game-tile-back" style="background: linear-gradient(135deg, rgba(93,63,211,0.15), rgba(72,61,139,0.2));">${face.src}</div>`;
          el.innerHTML = `
            <div class="game-tile-inner">
              <div class="game-tile-front"></div>
              ${backContent}
            </div>`;
          gameBoard.appendChild(el);
          return { id, pairId, emoji: face.src, el };
        });

        gameState.startTime = 0;
      }

      function startTimerIfNeeded() {
        if (gameState.startTime > 0) return;
        gameState.startTime = performance.now();
        function tick() {
          if (gameState.phase === 'complete') return;
          gameTimerEl.textContent = formatGameTime(performance.now() - gameState.startTime);
          gameState.timerRaf = requestAnimationFrame(tick);
        }
        gameState.timerRaf = requestAnimationFrame(tick);
      }

      function flipTile(tile: GameTile, show: boolean) {
        tile.el.classList.toggle('flipped', show);
      }

      function onGameComplete() {
        gameState.phase = 'complete';
        cancelAnimationFrame(gameState.timerRaf);
        const elapsed = performance.now() - gameState.startTime;
        lastGameElapsed = elapsed;
        const config = DIFFICULTY_CONFIG[gameState.difficulty];
        const score = calcGameScore(gameState.moves, elapsed, config.pairs);
        gameTimerEl.textContent = formatGameTime(elapsed);
        gameScoreEl.textContent = `Score: ${score.toLocaleString()}`;
        gameFinalEl.textContent = `${gameState.moves} moves in ${formatGameTime(elapsed)} — Score: ${score.toLocaleString()}`;

        // Reset submit button state
        gameSubmitBtn.disabled = false;
        gameSubmitBtn.textContent = 'Submit Score';
        gameSubmitStatus.classList.add('hidden');

        // Name handling: use RSVP name if available, otherwise show input
        const rsvpName = getPlayerName();
        if (rsvpName) {
          gameNameRow.classList.add('hidden');
          gameNameGreeting.textContent = `Playing as ${rsvpName}`;
          gameNameGreeting.classList.remove('hidden');
          gameNameInput.value = rsvpName;
        } else {
          gameNameRow.classList.remove('hidden');
          gameNameGreeting.classList.add('hidden');
          gameNameInput.value = '';
          setTimeout(() => gameNameInput.focus(), 100);
        }

        gameOverEl.classList.remove('hidden');
      }

      gameBoard.addEventListener('click', (e) => {
        const tileEl = (e.target as HTMLElement).closest('.game-tile') as HTMLElement | null;
        if (!tileEl) return;
        const id = Number(tileEl.dataset.id);
        const tile = gameState.tiles[id];
        if (!tile) return;

        if (gameState.phase === 'checking' || gameState.phase === 'complete') return;
        if (gameState.matchedPairs.has(tile.pairId)) return;
        if (gameState.firstPick?.id === tile.id) return;

        startTimerIfNeeded();
        flipTile(tile, true);

        if (gameState.phase === 'ready') {
          gameState.firstPick = tile;
          gameState.phase = 'first_pick';
          return;
        }

        gameState.phase = 'checking';
        gameState.moves++;
        gameMovesEl.textContent = `Moves: ${gameState.moves}`;

        if (tile.pairId === gameState.firstPick!.pairId) {
          gameState.matchedPairs.add(tile.pairId);
          tile.el.classList.add('matched');
          gameState.firstPick!.el.classList.add('matched');
          gameState.firstPick = null;
          const config = DIFFICULTY_CONFIG[gameState.difficulty];
          if (gameState.matchedPairs.size === config.pairs) {
            onGameComplete();
          } else {
            gameState.phase = 'ready';
          }
        } else {
          tile.el.classList.add('wrong');
          gameState.firstPick!.el.classList.add('wrong');
          const a = gameState.firstPick!;
          const b = tile;
          setTimeout(() => {
            flipTile(a, false);
            flipTile(b, false);
            a.el.classList.remove('wrong');
            b.el.classList.remove('wrong');
            gameState.firstPick = null;
            gameState.phase = 'ready';
          }, 800);
        }
      });

      document.getElementById('game-difficulty')!.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.game-diff-btn') as HTMLElement | null;
        if (!btn) return;
        document.querySelectorAll('.game-diff-btn').forEach(b => {
          (b as HTMLElement).style.borderColor = 'hsl(270, 30%, 40%)';
          (b as HTMLElement).style.color = 'hsl(270, 30%, 65%)';
          (b as HTMLElement).style.background = 'transparent';
        });
        btn.style.borderColor = '#FFB6D9';
        btn.style.color = '#FFB6D9';
        btn.style.background = 'rgba(255,182,217,0.1)';
        startGame(btn.dataset.diff!);
        fetchLeaderboard(btn.dataset.diff!);
      });

      document.getElementById('game-play-again')!.addEventListener('click', () => {
        startGame(gameState.difficulty);
      });

      gameSubmitBtn.addEventListener('click', submitScore);

      // Allow Enter in name input to submit
      gameNameInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') submitScore();
      });

      document.getElementById('disco-ball-click')!.addEventListener('click', () => {
        gameModal.classList.remove('hidden');
        startGame(gameState.difficulty);
        fetchLeaderboard(gameState.difficulty);
      });

      document.getElementById('game-close')!.addEventListener('click', () => {
        gameModal.classList.add('hidden');
        cancelAnimationFrame(gameState.timerRaf);
        gameState.phase = 'idle';
      });

      gameModal.addEventListener('click', (e) => {
        if (e.target === gameModal) {
          gameModal.classList.add('hidden');
          cancelAnimationFrame(gameState.timerRaf);
          gameState.phase = 'idle';
        }
      });

      // ── Calendar transition ──
      const calBtn = document.getElementById('cal-btn')!;
      const calUrl = calBtn.getAttribute('href')!;

      // Restore everything on back-navigation (bfcache)
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) {
          const s = document.getElementById('sunburst-svg');
          const sp = document.getElementById('sparkle-field');
          const m = document.querySelector('main');
          const st = document.querySelector('.stripe-panel');
          if (s) { s.style.width = '400vmax'; s.style.height = '400vmax'; }
          if (sp) (sp as HTMLElement).style.transform = '';
          if (m) m.classList.remove('cal-transition-hide');
          if (st) st.classList.remove('cal-transition-hide');
          document.querySelectorAll('.cal-big-icon').forEach(el => el.remove());
        }
      });

      calBtn.addEventListener('click', (e) => {
        e.preventDefault();

        // Create big calendar icon on click
        const bigIcon = document.createElement('div');
        bigIcon.setAttribute('style',
          `position:fixed;top:0;left:0;width:${window.innerWidth}px;height:${window.innerHeight}px;` +
          `display:flex;align-items:center;justify-content:center;z-index:99999;pointer-events:none;` +
          `opacity:0;transition:opacity 0.6s ease;`
        );
        bigIcon.innerHTML = `<svg viewBox="0 0 24 24" width="120" height="120" fill="none" stroke="#483D8B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>`;
        document.body.appendChild(bigIcon);

        // Hide everything except rays, sparkles, clouds, and the big icon
        const main = document.querySelector('main')!;
        const stripePanel = document.querySelector('.stripe-panel')!;
        const sunburst = document.getElementById('sunburst-svg')!;
        const sparkles = document.getElementById('sparkle-field')!;
        const clouds = document.getElementById('clouds-container')!;

        main.classList.add('cal-transition-hide');
        stripePanel.classList.add('cal-transition-hide');

        // Shrink rays and stars to icon size
        sunburst.style.width = '120px';
        sunburst.style.height = '120px';
        sparkles.style.transform = 'scale(0.03)';

        // Show big calendar icon
        setTimeout(() => { bigIcon.style.opacity = '1'; }, 400);

        // Flip the icon in the last 0.5s
        setTimeout(() => {
          const svg = bigIcon.querySelector('svg')!;
          (svg as HTMLElement).style.animation = 'cal-flip 0.5s ease-in-out';
        }, 1000);

        // Open calendar after 1.5s
        setTimeout(() => {
          window.open(calUrl, '_blank', 'noopener,noreferrer');
          // Restore everything
          bigIcon.style.opacity = '0';
          sunburst.style.width = '400vmax';
          sunburst.style.height = '400vmax';
          sparkles.style.transform = '';
          setTimeout(() => {
            main.classList.remove('cal-transition-hide');
            stripePanel.classList.remove('cal-transition-hide');
            bigIcon.remove();
          }, 500);
        }, 1500);
      });

    </script>
  </body>
</html>
