        <!-- Fill covers -->
        <div class="absolute rounded-full" style="width: 130px; height: 90px; background: #ffffff; top: 0; left: -5px;"></div>
        <div class="absolute rounded-full" style="width: 120px; height: 80px; background: #ffffff; top: 20px; left: 30px;"></div>
        <div class="absolute rounded-full" style="width: 100px; height: 70px; background: #ffffff; top: 40px; left: 10px;"></div>
        <div class="absolute rounded-full" style="width: 90px; height: 60px; background: #ffffff; top: 15px; left: 75px;"></div>
        <!-- Trailing bubbles down left (tight chain) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 55px; height: 55px; background: #ffffff; top: 105px; left: 5px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 30px; height: 30px; background: #ffffff; top: 110px; left: 48px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 40px; height: 40px; background: #ffffff; top: 150px; left: 10px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 18px; height: 18px; background: #ffffff; top: 152px; left: 45px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 25px; height: 25px; background: #ffffff; top: 183px; left: 8px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 14px; height: 14px; background: #ffffff; top: 186px; left: 30px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 18px; height: 18px; background: #ffffff; top: 203px; left: 15px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 10px; height: 10px; background: #ffffff; top: 218px; left: 10px;"></div>
        <!-- Along top edge (overlapping main cluster) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 25px; height: 25px; background: #ffffff; top: 8px; left: 150px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 15px; height: 15px; background: #ffffff; top: 18px; left: 172px;"></div>
      </div>

      <!-- Top-right cloud (cluster + trailing bubbles) -->
      <div class="absolute" style="top: -40px; right: -40px;">
        <div class="cloud-bubble absolute rounded-full" style="width: 115px; height: 115px; background: #ffffff; top: 0; right: 0;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 95px; height: 95px; background: #ffffff; top: 30px; right: 30px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 80px; height: 80px; background: #ffffff; top: 10px; right: 85px;"></div>
        <!-- Fill covers -->
        <div class="absolute rounded-full" style="width: 125px; height: 85px; background: #ffffff; top: 0; right: -5px;"></div>
        <div class="absolute rounded-full" style="width: 105px; height: 70px; background: #ffffff; top: 15px; right: 25px;"></div>
        <div class="absolute rounded-full" style="width: 90px; height: 55px; background: #ffffff; top: 5px; right: 60px;"></div>
        <!-- Trailing bubbles down right side (tight chain) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 50px; height: 50px; background: #ffffff; top: 100px; right: 5px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 22px; height: 22px; background: #ffffff; top: 105px; right: 48px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 35px; height: 35px; background: #ffffff; top: 140px; right: 10px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 15px; height: 15px; background: #ffffff; top: 145px; right: 40px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 24px; height: 24px; background: #ffffff; top: 168px; right: 5px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 12px; height: 12px; background: #ffffff; top: 188px; right: 14px;"></div>
        <!-- Along top (tight chain from main cluster) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 45px; height: 45px; background: #ffffff; top: 8px; right: 130px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 20px; height: 20px; background: #ffffff; top: 32px; right: 128px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 30px; height: 30px; background: #ffffff; top: 5px; right: 170px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 14px; height: 14px; background: #ffffff; top: 20px; right: 197px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 18px; height: 18px; background: #ffffff; top: 3px; right: 208px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 10px; height: 10px; background: #ffffff; top: 12px; right: 224px;"></div>
      </div>
    </div>

    <!-- ═══ Floating sparkles (mouse-parallax depth layers) ═══ -->
    <div id="sparkle-field" class="fixed inset-0 pointer-events-none z-[1] overflow-hidden" style="transition: transform 1.5s ease-in-out;">
      <!-- Layer 1: slow/far sparkles -->
      <div class="sparkle-layer" data-depth="0.02">
        <svg class="sparkle" style="top: 5%; left: 8%; animation-delay: 0s;" viewBox="0 0 24 24" width="14" height="14"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 45%; left: 85%; animation-delay: 1.2s;" viewBox="0 0 24 24" width="10" height="10"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#e85d20" /></svg>
        <svg class="sparkle" style="top: 78%; left: 22%; animation-delay: 2.4s;" viewBox="0 0 24 24" width="12" height="12"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 18%; left: 48%; animation-delay: 3.5s;" viewBox="0 0 24 24" width="11" height="11"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#cc5500" /></svg>
        <svg class="sparkle" style="top: 62%; left: 68%; animation-delay: 0.8s;" viewBox="0 0 24 24" width="13" height="13"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#f0a818" /></svg>
        <svg class="sparkle" style="top: 90%; left: 52%; animation-delay: 2.1s;" viewBox="0 0 24 24" width="9" height="9"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 35%; left: 5%; animation-delay: 4.2s;" viewBox="0 0 24 24" width="10" height="10"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#e85d20" /></svg>
        <svg class="sparkle" style="top: 55%; left: 92%; animation-delay: 1.6s;" viewBox="0 0 24 24" width="11" height="11"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#f0a818" /></svg>
      </div>
      <!-- Layer 2: medium sparkles -->
      <div class="sparkle-layer" data-depth="0.05">
        <svg class="sparkle" style="top: 25%; left: 72%; animation-delay: 0.7s;" viewBox="0 0 24 24" width="18" height="18"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 65%; left: 15%; animation-delay: 1.8s;" viewBox="0 0 24 24" width="16" height="16"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#cc5500" /></svg>
        <svg class="sparkle" style="top: 88%; left: 65%; animation-delay: 3.1s;" viewBox="0 0 24 24" width="13" height="13"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#e85d20" /></svg>
        <svg class="sparkle" style="top: 10%; left: 32%; animation-delay: 0.3s;" viewBox="0 0 24 24" width="15" height="15"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 42%; left: 58%; animation-delay: 2.5s;" viewBox="0 0 24 24" width="14" height="14"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#f0a818" /></svg>
        <svg class="sparkle" style="top: 75%; left: 40%; animation-delay: 3.8s;" viewBox="0 0 24 24" width="17" height="17"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 15%; left: 88%; animation-delay: 1.1s;" viewBox="0 0 24 24" width="12" height="12"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#cc5500" /></svg>
        <svg class="sparkle" style="top: 50%; left: 3%; animation-delay: 4.0s;" viewBox="0 0 24 24" width="15" height="15"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#e85d20" /></svg>
      </div>
      <!-- Layer 3: close/fast sparkles -->
      <div class="sparkle-layer" data-depth="0.1">
        <svg class="sparkle" style="top: 8%; left: 55%; animation-delay: 0.4s;" viewBox="0 0 24 24" width="22" height="22"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 52%; left: 42%; animation-delay: 2.0s;" viewBox="0 0 24 24" width="20" height="20"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#cc5500" /></svg>
        <svg class="sparkle" style="top: 30%; left: 18%; animation-delay: 1.4s;" viewBox="0 0 24 24" width="24" height="24"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#f0a818" /></svg>
        <svg class="sparkle" style="top: 70%; left: 78%; animation-delay: 3.3s;" viewBox="0 0 24 24" width="21" height="21"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#FFD700" /></svg>
        <svg class="sparkle" style="top: 85%; left: 25%; animation-delay: 0.9s;" viewBox="0 0 24 24" width="19" height="19"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#e85d20" /></svg>
        <svg class="sparkle" style="top: 20%; left: 95%; animation-delay: 2.7s;" viewBox="0 0 24 24" width="18" height="18"><polygon points="12,0 14.5,9.5 24,12 14.5,14.5 12,24 9.5,14.5 0,12 9.5,9.5" stroke="#2a1a0a" stroke-width="1" fill="#f0a818" /></svg>
      </div>
    </div>

    <style>
      .bar-fade-right {}
      .bar-fade-left {}
      .cal-transition-hide {
        transition: opacity 0.8s ease-out;
        opacity: 0 !important;
      }
      .cal-big-icon {}
      .cal-big-icon.show {}
      #rsvp-btn:hover .rsvp-shine {
        animation: shine-sweep-reverse 0.6s ease-in-out forwards !important;
      }
      .cloud-bubble {}
      .sparkle-layer {
        position: absolute;
        inset: 0;
        transition: transform 0.15s ease-out;
      }
      body.accent-pink .slide-text {
        color: #FF80C0 !important;
      }
      body.accent-pink .sparkle polygon {
        fill: #FF80C0 !important;
      }
      .sparkle {
        position: absolute;
        animation: sparkle 3s ease-in-out infinite;
      }
      .guest-list-fade-in {
        opacity: 0;
        animation: fade-in-guests 0.8s ease-out 5.2s forwards;
      }
      @keyframes fade-in-guests {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>

    <main class="relative z-10 max-w-[791px] mx-auto px-phi-lg py-phi-3xl">

      <!-- ═══ Disco Ball Hero ═══ -->
      <header class="text-center space-y-phi-lg flex flex-col justify-end relative" style="min-height: 0;">
        <!-- Mini disco ball motif (hidden for now)
        <div class="mx-auto w-[89px] h-[89px] rounded-full relative"
             style="background: conic-gradient(from 0deg, #BCC6CC, #FFD700, #BCC6CC, #5D3FD3, #BCC6CC, #FF007F, #BCC6CC, #FFD700);
                    animation: disco-rotate 8s linear infinite;
                    box-shadow: 0 0 34px hsl(45, 100%, 50% / 0.4), 0 0 55px hsl(280, 60%, 50% / 0.2);">
          <div class="absolute inset-0 rounded-full opacity-40"
               style="background:
                 repeating-linear-gradient(0deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px),
                 repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(0,0,0,0.3) 8px, rgba(0,0,0,0.3) 9px);">
          </div>
        </div>
        -->

        <!-- Purpose statement (absolute, doesn't affect flow) -->
        <!-- Arc text + disco ball unit (bounces in after slide-in) -->
        <div class="arc-disco-unit" style="position: absolute; top: 0px; left: 50%; transform: translateX(-50%) translateY(-120vh); width: max-content; animation: bounce-in 1.2s ease-in 6s forwards;">
        <svg viewBox="0 0 2750 1375" class="arc-text-svg w-full max-w-[600px] overflow-visible" style="display: block;" >
          <defs>
            <path id="text-arc" d="M 650,1350 A 650,650 0 0,1 2100,1350" fill="none" />
          </defs>
          <!-- Sun circle (behind disco ball) -->
          <text style="font-family: 'Chicle', sans-serif; font-size: 132px; font-weight: 500;
                       letter-spacing: 0.05em;"
                fill="#483D8B">
            <textPath href="#text-arc" startOffset="50%" text-anchor="middle">
              Let's celebrate Alina's first year of life!
            </textPath>
          </text>
        </svg>

        <!-- Cartoon disco ball (replaces sun) -->
        <div class="disco-ball-scene" style="width: 600px; max-width: 100%; display: flex; align-items: center; justify-content: center; pointer-events: none; margin: 0 auto;">
          <div class="disco-ball-wrapper" style="perspective: 600px; position: relative;">
            <!-- Iridescent background circle behind tiles -->
