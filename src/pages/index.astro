---
import '../styles/global.css'
import { SEVENTIES_SONGS, formatSongDisplay } from '../data/seventies-songs'
import MusicSearchWidget from '../components/MusicSearchWidgetDynamic.astro'
---

<html lang="en" style="overflow-x: hidden;">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>You're Invited</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Chicle&family=Righteous&family=Poppins:wght@400;500;600;700&family=Caprasimo&family=Fredoka:wght@600&family=Baloo+2:wght@700&family=Monoton&family=Bungee+Shade&family=Pacifico&family=Rubik+Bubbles&family=Shrikhand&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen overflow-x-hidden relative"
        style="font-family: 'Righteous', sans-serif;
               background: #6BB8FF;">



    <!-- ═══ Sunburst background (multi-color rays, parallax back layer) ═══ -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" style="z-index: -2;">
    <div id="sunburst-container" class="sunburst-bg sparkle-layer w-full h-full flex items-center justify-center overflow-visible"
         data-depth="0.008"
         style="opacity: 1; transition: transform 1.5s ease-in-out;">
      <svg id="sunburst-svg" viewBox="0 0 1000 1000" style="width: 400vmax; height: 400vmax; border-radius: 50%; animation: disco-rotate 180s linear infinite; flex-shrink: 0; transition: transform 1.5s ease-in-out, width 1.5s ease-in-out, height 1.5s ease-in-out;">
        {(() => {
          const colors = ['#C0E4FF', '#B0F0FF', '#CCE4FF', '#FFE8FF', '#C0E4FF', '#D0F0FF', '#CCE4FF', '#B8ECFF', '#B0F0FF', '#FFE8FF', '#D0F0FF', '#C0E4FF'];
          const rays = [];
          const count = 36;
          const angleStep = 360 / count;
          const cx = 500, cy = 500, r = 600;
          for (let i = 0; i < count; i++) {
            const a1 = (i * angleStep - 90) * Math.PI / 180;
            const a2 = ((i + 1) * angleStep - 90) * Math.PI / 180;
            const x1 = cx + r * Math.cos(a1);
            const y1 = cy + r * Math.sin(a1);
            const x2 = cx + r * Math.cos(a2);
            const y2 = cy + r * Math.sin(a2);
            rays.push(
              <polygon
                points={`${cx},${cy} ${x1},${y1} ${x2},${y2}`}
                fill={colors[i % colors.length]}
              />
            );
          }
          return rays;
        })()}
        <!-- Center circle -->
      </svg>
    </div>
    </div>

    <!-- ═══ Corner clouds (stacked circles, tucked into corners) ═══ -->
    <div id="clouds-container" class="fixed inset-0 pointer-events-none" style="z-index: -1;">
      <!-- Bottom-left cloud -->
      <div class="absolute" style="bottom: -40px; left: -40px;">
        <div class="cloud-bubble absolute rounded-full" style="width: 130px; height: 130px; background: #ffffff; bottom: 0; left: 0;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 80px; height: 80px; background: #ffffff; bottom: 50px; left: 55px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 65px; height: 65px; background: #ffffff; bottom: 20px; left: 100px;"></div>
        <!-- Trailing cluster up the left edge (tight chain) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 45px; height: 45px; background: #ffffff; bottom: 85px; left: 10px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 28px; height: 28px; background: #ffffff; bottom: 85px; left: 48px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 35px; height: 35px; background: #ffffff; bottom: 120px; left: 5px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 18px; height: 18px; background: #ffffff; bottom: 118px; left: 36px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 22px; height: 22px; background: #ffffff; bottom: 148px; left: 12px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 14px; height: 14px; background: #ffffff; bottom: 166px; left: 8px;"></div>
        <!-- Mini cluster drifting right (overlapping main) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 20px; height: 20px; background: #ffffff; bottom: 45px; left: 130px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 12px; height: 12px; background: #ffffff; bottom: 55px; left: 148px;"></div>
        <!-- Fill covers -->
        <div class="absolute rounded-full" style="width: 140px; height: 100px; background: #ffffff; bottom: 0; left: -10px;"></div>
        <div class="absolute rounded-full" style="width: 120px; height: 85px; background: #ffffff; bottom: 5px; left: 20px;"></div>
        <div class="absolute rounded-full" style="width: 110px; height: 80px; background: #ffffff; bottom: 0; left: 50px;"></div>
        <div class="absolute rounded-full" style="width: 100px; height: 70px; background: #ffffff; bottom: 15px; left: 5px;"></div>
      </div>

      <!-- Bottom-right cloud -->
      <div class="absolute" style="bottom: -35px; right: -30px;">
        <div class="cloud-bubble absolute rounded-full" style="width: 110px; height: 110px; background: #ffffff; bottom: 0; right: 0;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 100px; height: 100px; background: #ffffff; bottom: 10px; right: 65px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 70px; height: 70px; background: #ffffff; bottom: 40px; right: 15px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 45px; height: 45px; background: #ffffff; bottom: 30px; right: 125px;"></div>
        <!-- Trailing up right edge (tight chain) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 40px; height: 40px; background: #ffffff; bottom: 80px; right: 8px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 25px; height: 25px; background: #ffffff; bottom: 82px; right: 42px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 30px; height: 30px; background: #ffffff; bottom: 112px; right: 12px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 16px; height: 16px; background: #ffffff; bottom: 138px; right: 10px;"></div>
        <!-- Scattered along bottom (overlapping main) -->
        <div class="cloud-bubble absolute rounded-full" style="width: 22px; height: 22px; background: #ffffff; bottom: 18px; right: 135px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 15px; height: 15px; background: #ffffff; bottom: 8px; right: 150px;"></div>
        <!-- Fill covers -->
        <div class="absolute rounded-full" style="width: 130px; height: 80px; background: #ffffff; bottom: 0; right: -5px;"></div>
        <div class="absolute rounded-full" style="width: 110px; height: 65px; background: #ffffff; bottom: 0; right: 50px;"></div>
        <div class="absolute rounded-full" style="width: 80px; height: 55px; background: #ffffff; bottom: 5px; right: 20px;"></div>
      </div>

      <!-- Top-left cloud (larger cluster + trailing bubbles) -->
      <div class="absolute" style="top: -40px; left: -40px;">
        <div class="cloud-bubble absolute rounded-full" style="width: 120px; height: 120px; background: #ffffff; top: 0; left: 0;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 100px; height: 100px; background: #ffffff; top: 30px; left: 50px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 90px; height: 90px; background: #ffffff; top: 10px; left: 100px;"></div>
        <div class="cloud-bubble absolute rounded-full" style="width: 80px; height: 80px; background: #ffffff; top: 55px; left: 25px;"></div>
