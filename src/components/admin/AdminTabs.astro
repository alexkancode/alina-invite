---
interface Tab {
  id: string;
  label: string;
  icon?: string;
}

interface Props {
  tabs: Tab[];
  defaultTab?: string;
}

const { tabs, defaultTab = 'photos' } = Astro.props;
---

<div class="admin-tabs">
  <nav class="tab-nav" role="tablist">
    {tabs.map((tab, index) => (
      <button
        class={`tab-button ${tab.id === defaultTab ? 'active' : ''}`}
        data-tab={tab.id}
        role="tab"
        aria-controls={`panel-${index}`}
        id={`tab-${index}`}
        tabindex={tab.id === defaultTab ? '0' : '-1'}
      >
        {tab.icon && <span class="tab-icon">{tab.icon}</span>}
        {tab.label}
      </button>
    ))}
  </nav>

  <div class="tab-content">
    <div
      class={`tab-panel ${defaultTab === 'photos' ? 'active' : 'hidden'}`}
      data-panel="photos"
      role="tabpanel"
      aria-labelledby="tab-0"
      id="panel-0"
    >
      <slot name="photos" />
    </div>
    <div
      class={`tab-panel ${defaultTab === 'overlays' ? 'active' : 'hidden'}`}
      data-panel="overlays"
      role="tabpanel"
      aria-labelledby="tab-1"
      id="panel-1"
    >
      <slot name="overlays" />
    </div>
  </div>
</div>

<script>
  import { AdminTabsController } from '../../lib/admin/AdminTabsController.js';

  if (typeof window !== 'undefined') {
    new AdminTabsController();
  }
</script>

<style>
  .admin-tabs {
    background: var(--color-paper);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-elevation-medium);
  }

  .tab-nav {
    display: flex;
    background: var(--color-ink);
    border-bottom: 1px solid var(--color-border);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tab-button {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-muted);
    padding: var(--spacing-phi-md) var(--spacing-phi-lg);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-phi-xs);
    position: relative;
  }

  .tab-button:hover {
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
    color: var(--color-paper);
  }

  .tab-button:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .tab-button.active {
    background: var(--color-accent);
    color: var(--color-paper);
  }

  .tab-button.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-paper);
  }

  .tab-icon {
    font-size: 1.2em;
  }

  .tab-content {
    padding: var(--spacing-phi-lg);
    min-height: 400px;
  }

  .tab-panel {
    transition: opacity 0.2s ease;
  }

  .tab-panel.hidden {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  @media (max-width: 768px) {
    .tab-nav {
      flex-direction: column;
    }

    .tab-button {
      text-align: left;
      padding: var(--spacing-phi-sm) var(--spacing-phi-md);
    }

    .tab-content {
      padding: var(--spacing-phi-md);
    }
  }
</style>