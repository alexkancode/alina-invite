---
import { buildFryCrowd, CROWD_SEED, FRY_COUNT, HEADLINE_LINES, SCENE_TIMELINE, WAVE_EDGE_PATH } from '../../lib/yait/heroScene';

const fries = buildFryCrowd(FRY_COUNT, CROWD_SEED);

const fryStyle = (fry: (typeof fries)[number]) =>
  `--fry-h: ${fry.heightPx}px; --fry-hue: ${fry.hue}; --fry-amp: ${fry.bounceAmplitudePx}px; ` +
  `--fry-delay: ${SCENE_TIMELINE.bounceStartMs + fry.bounceDelayMs}ms; --lean-delay: ${fry.leanDelayMs}ms`;
---

<section class="bay" data-testid="hero-bay">
  <svg class="bay-scene" viewBox="0 0 1200 675" preserveAspectRatio="xMidYMid slice" role="img" aria-label="A big envelope full of happy little passengers sails into a sunny coastal bay and pulls up to the dock">
    <defs>
      <linearGradient id="yait-sky-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#F9C784"></stop>
        <stop offset="100%" stop-color="#FBE3BC"></stop>
      </linearGradient>
      <clipPath id="yait-wave-clip" clipPathUnits="objectBoundingBox">
        <path d={WAVE_EDGE_PATH}></path>
      </clipPath>
    </defs>
    <rect x="0" y="0" width="1200" height="420" fill="url(#yait-sky-grad)"></rect>
    <circle cx="940" cy="140" r="78" fill="#F4A259" opacity="0.45"></circle>
    <circle cx="940" cy="140" r="58" fill="#F4A259"></circle>
    <rect x="180" y="120" width="130" height="26" rx="13" fill="#F4E8D1" opacity="0.85"></rect>
    <rect x="230" y="96" width="80" height="22" rx="11" fill="#F4E8D1" opacity="0.7"></rect>
    <rect x="640" y="200" width="100" height="22" rx="11" fill="#F4E8D1" opacity="0.6"></rect>
    <path d="M390 180 q12 -12 24 0 q12 -12 24 0" fill="none" stroke="#264653" stroke-width="4" stroke-linecap="round"></path>
    <path d="M500 230 q10 -10 20 0 q10 -10 20 0" fill="none" stroke="#264653" stroke-width="3.5" stroke-linecap="round"></path>
    <path d="M0 420 L0 296 Q90 268 170 318 Q240 364 300 420 Z" fill="#264653"></path>
    <rect x="0" y="420" width="1200" height="255" fill="#2A9D8F"></rect>
    <path d="M60 480 q30 -10 60 0" fill="none" stroke="#F4E8D1" stroke-width="4" stroke-linecap="round" opacity="0.3"></path>
    <path d="M320 560 q34 -10 68 0" fill="none" stroke="#F4E8D1" stroke-width="4" stroke-linecap="round" opacity="0.25"></path>
    <path d="M540 500 q30 -10 60 0" fill="none" stroke="#F4E8D1" stroke-width="4" stroke-linecap="round" opacity="0.3"></path>
    <path d="M980 590 q34 -10 68 0" fill="none" stroke="#F4E8D1" stroke-width="4" stroke-linecap="round" opacity="0.25"></path>
    <g class="dock">
      <rect x="770" y="462" width="430" height="16" rx="8" fill="#264653"></rect>
      <rect x="800" y="478" width="14" height="60" fill="#264653"></rect>
      <rect x="900" y="478" width="14" height="68" fill="#264653"></rect>
      <rect x="1010" y="478" width="14" height="78" fill="#264653"></rect>
      <rect x="1120" y="478" width="14" height="86" fill="#264653"></rect>
      <rect x="1185" y="478" width="14" height="92" fill="#264653"></rect>
    </g>
  </svg>

  <p class="wordmark">yait<span class="wordmark-note">rhymes with "yacht"</span></p>

  <div class="headline-mask">
    <h1 class="headline">
      {HEADLINE_LINES.map((line, index) => (
        <span class={index === 0 ? 'line-mask line-mask-top' : 'line-mask'}>
          <span class={index === 0 ? 'headline-line' : 'headline-line headline-line-indent'}>
            {line.map(word => (
              <span class="word">{word}</span>
            ))}
          </span>
        </span>
      ))}
    </h1>
  </div>

  <div class="envelope-track" data-testid="envelope">
    <div class="envelope">
    <svg class="envelope-flap" viewBox="0 0 200 140">
      <rect class="interior" x="10" y="88" width="180" height="50" fill="#EBDCC0"></rect>
      <circle class="seal" cx="100" cy="16" r="10" fill="#E76F51" stroke="#264653" stroke-width="3.5"></circle>
      <path d="M 12 90 L 100 8 L 188 90 Z" fill="#EBDCC0" stroke="#264653" stroke-width="4" stroke-linejoin="round"></path>
    </svg>
    <div class="fries">
      {fries.map(fry => (
        <div class="fry" data-face={fry.face} style={fryStyle(fry)}></div>
      ))}
    </div>
    <svg class="envelope-art" viewBox="0 0 200 140">
      <ellipse cx="100" cy="133" rx="86" ry="6" fill="#F4E8D1" opacity="0.5"></ellipse>
      <path d="M 4 38 L 100 80 L 196 38 L 196 118 Q 196 128 186 128 L 14 128 Q 4 128 4 118 Z" fill="#F4E8D1" stroke="#264653" stroke-width="4" stroke-linejoin="round"></path>
      <line x1="14" y1="38" x2="14" y2="10" stroke="#264653" stroke-width="3.5" stroke-linecap="round"></line>
      <path d="M14 10 L44 18 L14 26 Z" fill="#E76F51" stroke="#264653" stroke-width="2.5" stroke-linejoin="round"></path>
    </svg>
    </div>
  </div>

  <div class="grain" aria-hidden="true">
    <svg width="100%" height="100%">
      <filter id="yait-grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="2"></feTurbulence>
      </filter>
      <rect width="100%" height="100%" filter="url(#yait-grain)"></rect>
    </svg>
  </div>
</section>
