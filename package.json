{
  "name": "photo-upload-system",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:api": "vitest run",
    "test:e2e": "npx playwright test",
    "test": "vitest run && npx playwright test",
    "start": "npm run migrate && node ./dist/server/entry.mjs",
    "start:dev": "node ./dist/server/entry.mjs",
    "migrate": "npx tsx scripts/migrate.ts",
    "railway:deploy": "./scripts/railway-deploy-complete.sh",
    "railway:deploy:prefixed": "./scripts/railway-deploy-prefixed.sh",
    "railway:inventory": "./scripts/railway-inventory.sh",
    "railway:cleanup-analysis": "./scripts/railway-cleanup-analysis.sh",
    "railway:status": "./scripts/railway-status.sh",
    "railway:backup": "./scripts/railway-backup.sh",
    "railway:dev": "./scripts/railway-dev.sh",
    "party:deploy": "npm run build && railway service link party-app && railway up --detach",
    "party:status": "railway service link party-app && railway service status && railway logs --lines 5",
    "party:logs": "railway service link party-app && railway logs --follow",
    "party:backup": "railway service link postgres && railway database backup --name backup-$(date +%Y%m%d-%H%M%S)"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.7",
    "pg": "^8.21.0",
    "profanease": "^2.0.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.3",
    "vitest": "^3.2.4"
  }
}
