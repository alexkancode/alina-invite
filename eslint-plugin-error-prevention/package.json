{
  "name": "eslint-plugin-error-prevention",
  "version": "1.0.0",
  "type": "module",
  "description": "ESLint rules to prevent common backend error patterns",
  "main": "lib/index.js",
  "scripts": {
    "test": "mocha tests/**/*.test.js",
    "test:watch": "mocha tests/**/*.test.js --watch",
    "test:coverage": "nyc mocha tests/**/*.test.js"
