{
	"compatibility_date": "2026-05-23",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "mvp",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "match-game-leaderboard",
			"database_id": "local"
		}
	]
}